\n        return False, \"not_in_allowed_board_scope\"\r\n    return True, \"\"\r\n\r\n\r\ndef history_lookup_key(candidate: dict[str, Any]) -> str:\r\n    return clean_text(candidate.get(\"ticker\") or candidate.get(\"code\"))\r\n\r\n\r\ndef alternate_a_share_keys(value: str) -> list[str]:\r\n    text = clean_text(value).upper()\r\n    if text.endswith(\".SS\"):\r\n        return [text, text[:-3] + \".SH\", text[:-3]]\r\n    if text.endswith(\".SH\"):\r\n        return [text, text[:-3] + \".SS\", text[:-3]]\r\n    if text.endswith(\".SZ\"):\r\n        return [text, text[:-3]]\r\n    if re.fullmatch(r\"\\d{6}\", text):\r\n        try:\r\n            normalized = normalized_a_share_ticker(text)\r\n        except ValueError:\r\n            return [text]\r\n        return alternate_a_share_keys(normalized)\r\n    return [text]\r\n\r\n\r\ndef normalize_history_row(row: dict[str, Any]) -> dict[str, Any]:\r\n    return {\r\n        \"trade_date\": clean_text(row.get(\"trade_date\") or row.get(\"date\")),\r\n        \"open\": float(row.get(\"open\") or 0.0),\r\n        \"high\": float(row.get(\"high\") or 0.0),\r\n        \"low\": float(row.get(\"low\") or 0.0),\r\n        \"close\": float(row.get(\"close\") or 0.0),\r\n        \"vol\": float(row.get(\"vol\") or row.get(\"volume\") or 0.0),\r\n"}}
