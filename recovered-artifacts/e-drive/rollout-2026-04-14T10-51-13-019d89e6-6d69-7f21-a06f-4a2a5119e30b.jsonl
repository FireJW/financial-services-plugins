{"timestamp":"2026-04-14T03:49:00.687Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_2d4otlPmhDa0EhCoyq7ATqp7","output":"Exit code: 0\nWall time: 1 seconds\nOutput:\n        \"trim_reduce_zone\": deepcopy(safe_list(base_card.get(\"trim_reduce_zone\"))),\r\n        \"invalidation_level\": base_card.get(\"invalidation_level\"),\r\n        \"failure_condition\": clean_text(base_card.get(\"failure_condition\")),\r\n        \"promotion_path\": clean_text(next(iter(transition_watch_promotion_triggers(candidate, request)), \"\")),\r\n    }\r\n\r\n\r\ndef transition_watch_record(candidate: dict[str, Any], request: dict[str, Any], profile: FilterProfile) -> dict[str, Any]:\r\n    failures = [clean_text(value) for value in safe_list(candidate.get(\"hard_filter_failures\")) if clean_text(value)]\r\n    record = top_pick_record(candidate, request, profile, selection_mode=\"transition_watch\")\r\n    record[\"watch_reasons\"] = failures\r\n    record[\"watch_bucket\"] = transition_watch_bucket(candidate, request)\r\n    record[\"watch_bucket_label\"] = transition_watch_bucket_label(record[\"watch_bucket\"])\r\n    record[\"promotion_score\"] = transition_watch_promotion_score(candidate, request)\r\n    record[\"promotion_readiness\"] = transition_watch_readiness(float(record[\"promotion_score\"] or 0.0))\r\n    record[\"promotion_triggers\"] = transition_watch_promotion_triggers(candidate, request)\r\n    record[\"watch_trade_card\"] = transition_watch_trade_card(candidate, request, profile)\r\n    record[\"status\"] = \"watch\"\r\n    return record\r\n\r\n\r\ndef build_transition_watch(candidates: list[dict[str, Any]], request: dict[str, Any], profile: FilterProfile) -> list[dict[str, Any]]:\r\n    watch = [transition_watch_record(item, request, profile) for item in candidates if is_transition_watch_candidate(item, request)]\r\n    watch.sort(\r\n        key=lambda item: (\r\n            -transition_watch_bucket_priority(clean_text(item.get(\"watch_bucket\"))),\r\n            -(float(item.get(\"promotion_score\") or 0.0)),\r\n            -(float(item.get(\"score\") or 0.0)),\r\n            -(float(item.get(\"rs90\") or 0.0)),\r\n            -(float(safe_dict(item.get(\"score_components\")).get(\"market_regime_overlay_adjustment\") or 0.0)),\r\n        )\r\n    )\r\n    return watch[:5]\r\n\r\n\r\ndef transition_watch_bucket(candidate: dict[str, Any], request: dict[str, Any]) -> str:\r\n    failures = {clean_text(value) for value in safe_list(candidate.get(\"hard_filter_failures\")) if clean_text(value)}\r\n    if has_event_first_support(candidate, request):\r\n        if \"trend_template_failed\" in failures:\r\n            return \"event_first_trend_repair\"\r\n        if \"rs_below_threshold\" in failures:\r\n            return \"event_first_leadership_rebuild\"\r\n        if \"risk_reward_below_min\" in failures:\r\n            return \"event_first_risk_reset\"\r\n        return \"event_first_confirmable\"\r\n    if \"trend_template_failed\" in failures:\r\n        return \"trend_repair\"\r\n    if \"rs_below_threshold\" in failures:\r\n        return \"leadership_rebuild\"\r\n    if \"risk_reward_below_min\" in failures:\r\n        return \"risk_reward_reset\"\r\n    return \"watch\"\r\n\r\n\r\ndef transition_watch_promotion_triggers(candidate: dict[str, Any], request: dict[str, Any]) -> list[str]:\r\n    failures = {clean_text(value) for value in safe_list(candidate.get(\"hard_filter_failures\")) if clean_text(value)}\r\n    metrics = safe_dict(candidate.get(\"metrics\"))\r\n    triggers: list[str] = []\r\n    if \"trend_template_failed\" in failures:\r\n        ma20 = markdown_number(metrics.get(\"ma20\"))\r\n        ma50 = markdown_number(metrics.get(\"ma50\"))\r\n        triggers.append(f\"close reclaims short trend support around ma20 `{ma20}` and starts to repair toward ma50 `{ma50}`\")\r\n    if \"rs_below_threshold\" in failures:\r\n        triggers.append(f\"relative strength improves back toward threshold `{markdown_number(request.get('rs_threshold'))}`\")\r\n    if \"risk_reward_below_min\" in failures:\r\n        min_ratio = markdown_number(request.get(\"min_risk_reward_ratio\") or 1.5)\r\n        triggers.append(f\"either entry resets lower or base target expands enough to restore >= `{min_ratio}R`\")\r\n    scheduled = clean_text(safe_dict(candidate.get(\"structured_catalyst\")).get(\"scheduled_earnings_date\"))\r\n    if scheduled:\r\n        triggers.append(f\"price holds support into earnings date `{scheduled}` without losing catalyst credibility\")\r\n    deduped: list[str] = []\r\n    for trigger in triggers:\r\n        if trigger not in deduped:\r\n            deduped.append(trigger)\r\n    return deduped[:4]\r\n\r\n\r\ndef markdown_price_range(value: Any) -> str:\r\n    values = safe_list(value)\r\n    if len(values) == 2:\r\n        return f\"{values[0]} - {values[1]}\"\r\n    text = clean_text(value)\r\n    return text or \"n/a\"\r\n\r\n\r\ndef markdown_pct(value: Any) -> str:\r\n    if value is None or clean_text(value) == \"\":\r\n        return \"n/a\"\r\n    try:\r\n        return f\"{round(float(value), 2)}%\"\r\n    except (TypeError, ValueError):\r\n        return clean_text(value) or \"n/a\"\r\n\r\n\r\ndef markdown_number(value: Any, digits: int = 2) -> str:\r\n    if value is None or clean_text(value) == \"\":\r\n        return \"n/a\"\r\n    try:\r\n        return str(round(float(value), digits))\r\n    except (TypeError, ValueError):\r\n        return clean_text(value) or \"n/a\"\r\n\r\n\r\ndef markdown_cap(value: Any) -> str:\r\n    if value is None:\r\n        return \"n/a\"\r\n    try:\r\n        numeric = float(value)\r\n    except (TypeError, ValueError):\r\n        return clean_text(value) or \"n/a\"\r\n    if numeric <= 0:\r\n        return \"n/a\"\r\n    return f\"{round(numeric / 1e8, 2)}e8 CNY\"\r\n\r\n\r\ndef catalyst_label(catalyst: dict[str, Any]) -> str:\r\n    scheduled = clean_text(catalyst.get(\"scheduled_earnings_date\"))\r\n    if scheduled:\r\n        return scheduled\r\n    if catalyst.get(\"scheduled_earnings_recent_support_window\"):\r\n        return \"earnings_published_within_10d\"\r\n    if catalyst.get(\"performance_preview_or_flash_published_within_last_10_trading_days\"):\r\n        return \"preview_or_flash_within_10d\"\r\n    if catalyst.get(\"structured_company_event_within_window\"):\r\n        return \"company_event_within_window\"\r\n    if catalyst.get(\"structured_catalyst_within_window\"):\r\n        return \"structured_catalyst_within_window\"\r\n    return \"none\"\r\n\r\n\r\ndef catalyst_display_summary(catalyst: dict[str, Any], *, limit: int = 3) -> str:\r\n    display_events = [safe_dict(item) for item in safe_list(catalyst.get(\"display_events\")) if safe_dict(item)]\r\n    if not display_events:\r\n        return catalyst_label(catalyst)\r\n    labels: list[str] = []\r\n    seen_labels: set[str] = set()\r\n    company_event_count = 0\r\n    for event in display_events[:limit]:\r\n        event_type = clean_text(event.get(\"event_type\"))\r\n        event_date = clean_text(event.get(\"event_date\"))\r\n        title = clean_text(event.get(\"title\"))\r\n        label = \"\"\r\n        if event_type == \"scheduled_earnings\" and event_date:\r\n            label = f\"earnings:{event_date}\"\r\n        elif event_type == \"performance_preview\" and event_date:\r\n            label = f\"preview:{event_date}\"\r\n        elif event_type == \"structured_company_event\" and event_date and bool(catalyst.get(\"structured_company_event_within_window\")):\r\n            if company_event_count >= 1:\r\n                continue\r\n            label = f\"company_event:{event_date}\"\r\n        elif title and event_type in {\"scheduled_earnings\", \"performance_preview\"}:\r\n            label = title[:48]\r\n        if label and label not in seen_labels:\r\n            labels.append(label)\r\n            seen_labels.add(label)\r\n            if event_type == \"structured_company_event\":\r\n                company_event_count += 1\r\n    return \", \".join(labels) if labels else catalyst_label(catalyst)\r\n\r\n\r\ndef selection_mode_label(value: str) -> str:\r\n    mapping = {\r\n        \"strict\": \"strict\",\r\n        \"near_strict\": \"near_strict\",\r\n        \"weak_fallback\": \"weak_fallback\",\r\n        \"transition_watch\": \"transition_watch\",\r\n    }\r\n    return mapping.get(clean_text(value), clean_text(value) or \"n/a\")\r\n\r\n\r\n"}}
