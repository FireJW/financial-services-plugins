{"timestamp":"2026-04-14T02:56:57.295Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_4eFpK5r2A9C05yZtPpvizbmW","output":"Exit code: 0\nWall time: 0.6 seconds\nOutput:\n    metrics = safe_dict(candidate.get(\"metrics\"))\r\n    catalyst = safe_dict(candidate.get(\"structured_catalyst\"))\r\n    acceleration = safe_dict(candidate.get(\"acceleration\"))\r\n    theme_alignment = safe_dict(candidate.get(\"theme_alignment\"))\r\n    repair = safe_dict(candidate.get(\"repair_rebound\"))\r\n    vcp = safe_dict(candidate.get(\"vcp\"))\r\n\r\n    if profile.trend_policy == \"repair_rebound\":\r\n        repair_conditions = safe_dict(repair.get(\"conditions\"))\r\n        trend_score = min(\r\n            (8.0 if repair_conditions.get(\"close_gt_ma20\") else 0.0)\r\n            + (6.0 if repair_conditions.get(\"ma20_slope_5d_gt_zero\") else 0.0)\r\n            + (4.0 if repair_conditions.get(\"rebound_from_recent_low\") else 0.0)\r\n            + (4.0 if repair_conditions.get(\"close_near_ma50\") else 0.0)\r\n            + (3.0 if repair_conditions.get(\"distance_to_52w_high_lte_45pct\") else 0.0)\r\n            + (3.0 if repair_conditions.get(\"rsi14_in_repair_band\") else 0.0),\r\n            25.0,\r\n        )\r\n    else:\r\n        trend_score = min(\r\n            (5.0 if flags.get(\"close_gt_ma50\") else 0.0)\r\n            + (5.0 if flags.get(\"close_gt_ma150\") else 0.0)\r\n            + (5.0 if flags.get(\"close_gt_ma200\") else 0.0)\r\n            + (5.0 if flags.get(\"ma50_gt_ma150\") else 0.0)\r\n            + (5.0 if flags.get(\"ma150_gt_ma200\") else 0.0),\r\n            25.0,\r\n        )\r\n    rs90 = float(candidate.get(\"rs90\") or 0.0)\r\n    rs_score = 15.0 if rs90 >= 85 else 12.0 if rs90 >= 75 else 9.0 if rs90 >= 70 else 5.0 if rs90 >= 60 else 0.0\r\n    fundamental_score = 20.0 if acceleration.get(\"fundamental_acceleration_pass\") else 10.0 if acceleration.get(\"latest_profit_yoy\") is not None and acceleration.get(\"latest_profit_yoy\", 0) >= 30 and acceleration.get(\"latest_revenue_yoy\") is not None and acceleration.get(\"latest_revenue_yoy\", 0) >= 20 else 0.0\r\n    # Downweight when fundamental sources conflict (>20pp gap on key metrics).\r\n    # A 50% haircut reflects that the acceleration signal is unreliable.\r\n    fundamental_source_conflict = safe_list(acceleration.get(\"fundamental_source_conflict\"))\r\n    if fundamental_source_conflict and fundamental_score > 0:\r\n        fundamental_score = round(fundamental_score * 0.5, 2)\r\n    catalyst_score = 15.0 if catalyst_policy_pass(candidate, profile) else 0.0\r\n    vcp_score = float(vcp.get(\"score\") or 0.0)\r\n    amount = float(candidate.get(\"turnover_amount\") or 0.0)\r\n    latest_amount = float(metrics.get(\"latest_amount\") or 0.0)\r\n    amount_ma20 = float(metrics.get(\"amount_ma20\") or 0.0)\r\n    liquidity_score = 0.0\r\n    liquidity_score += 5.0 if amount >= 8e9 else 3.0 if amount >= 5e9 else 0.0\r\n    liquidity_score += 5.0 if amount_ma20 > 0 and latest_amount >= amount_ma20 else 0.0\r\n    if liquidity_score == 0.0 and amount_ma20 >= DEFAULT_MIN_AVG_TURNOVER_20D:\r\n        liquidity_score = 5.0\r\n    liquidity_score = min(liquidity_score, 10.0)\r\n    cap_value = float(candidate.get(\"free_float_market_cap\") or candidate.get(\"total_market_cap\") or 0.0)\r\n    restore = acceleration.get(\"fundamental_acceleration_pass\") and catalyst.get(\"structured_catalyst_within_window\") and technical_integrity_pass(metrics)\r\n    cap_multiplier = giant_cap_multiplier(cap_value, profile, restore=restore)\r\n    cap_component = 5.0 * cap_multiplier\r\n    driver_theme_score = round(float(theme_alignment.get(\"score\") or 0.0), 2)\r\n    driver_theme_bonus = round(min(driver_theme_score * 0.2, 5.0), 2)\r\n    macro_health_adjustment, macro_health_reasons = macro_health_score_adjustment(candidate, request)\r\n    overlay_adjustment, overlay_reasons = overlay_score_adjustment(candidate, request)\r\n    x_style_adjustment, x_style_reasons = x_style_overlay_adjustment(candidate, request)\r\n    oc_adjustment, oc_reasons = overnight_catalyst_adjustment(candidate, request)\r\n    return {\r\n        \"trend_template_score\": round(trend_score, 2),\r\n        \"rs_and_leadership_score\": round(rs_score, 2),\r\n        \"fundamental_acceleration_score\": round(fundamental_score, 2),\r\n        \"structured_catalyst_score\": round(catalyst_score, 2),\r\n        \"vcp_or_contraction_score\": round(vcp_score, 2),\r\n        \"liquidity_and_participation_score\": round(liquidity_score, 2),\r\n        \"cap_penalty_or_restore\": round(cap_component, 2),\r\n        \"cap_multiplier\": round(cap_multiplier, 2),\r\n        \"driver_theme_score\": driver_theme_score,\r\n        \"driver_theme_bonus\": driver_theme_bonus,\r\n        \"macro_health_overlay_adjustment\": macro_health_adjustment,\r\n        \"macro_health_overlay_adjustment_cap\": MACRO_HEALTH_OVERLAY_ADJUSTMENT_CAP,\r\n        \"macro_health_overlay_adjustment_reasons\": macro_health_reasons,\r\n        \"market_regime_overlay_adjustment\": overlay_adjustment,\r\n        \"market_regime_overlay_adjustment_cap\": OVERLAY_TOTAL_ADJUSTMENT_CAP,\r\n        \"market_regime_overlay_adjustment_reasons\": overlay_reasons,\r\n        \"x_style_overlay_adjustment\": x_style_adjustment,\r\n        \"x_style_overlay_adjustment_cap\": X_STYLE_OVERLAY_ADJUSTMENT_CAP,\r\n        \"x_style_overlay_adjustment_reasons\": x_style_reasons,\r\n        \"overnight_catalyst_adjustment\": oc_adjustment,\r\n        \"overnight_catalyst_adjustment_cap_upper\": OVERNIGHT_CATALYST_ADJUSTMENT_CAP_UPPER,\r\n        \"overnight_catalyst_adjustment_cap_lower\": OVERNIGHT_CATALYST_ADJUSTMENT_CAP_LOWER,\r\n        \"overnight_catalyst_adjustment_reasons\": oc_reasons,\r\n        \"fundamental_source_conflict\": fundamental_source_conflict,\r\n    }\r\n\r\n\r\ndef total_score(components: dict[str, Any]) -> float:\r\n    return round(\r\n        float(components.get(\"trend_template_score\", 0.0))\r\n        + float(components.get(\"rs_and_leadership_score\", 0.0))\r\n        + float(components.get(\"fundamental_acceleration_score\", 0.0))\r\n        + float(components.get(\"structured_catalyst_score\", 0.0))\r\n        + float(components.get(\"vcp_or_contraction_score\", 0.0))\r\n        + float(components.get(\"liquidity_and_participation_score\", 0.0))\r\n        + float(components.get(\"cap_penalty_or_restore\", 0.0))\r\n        + float(components.get(\"driver_theme_bonus\", 0.0))\r\n        + float(components.get(\"macro_health_overlay_adjustment\", 0.0))\r\n        + float(components.get(\"market_regime_overlay_adjustment\", 0.0))\r\n        + float(components.get(\"x_style_overlay_adjustment\", 0.0))\r\n        + float(components.get(\"overnight_catalyst_adjustment\", 0.0)),\r\n        2,\r\n    )\r\n\r\n\r\ndef ordered_price_range(first: float, second: float) -> list[float]:\r\n    low = round(min(first, second), 2)\r\n    high = round(max(first, second), 2)\r\n    return [low, high]\r\n\r\n\r\ndef midpoint(value_range: list[float]) -> float:\r\n    if len(value_range) != 2:\r\n        return 0.0\r\n    return (float(value_range[0]) + float(value_range[1])) / 2.0\r\n\r\n\r\ndef candidate_invalidation_level(candidate: dict[str, Any], profile: FilterProfile | None = None) -> float:\r\n    metrics = safe_dict(candidate.get(\"metrics\"))\r\n    close = float(metrics.get(\"close\") or 0.0)\r\n    ma20 = float(metrics.get(\"ma20\") or float(\"nan\"))\r\n    low10 = float(metrics.get(\"low10\") or float(\"nan\"))\r\n    low20 = float(metrics.get(\"low20\") or float(\"nan\"))\r\n    support_levels = [close * 0.96]\r\n    # Only treat moving-average support as invalidation when that support is\r\n    # still below the current price. On pullback names trading below ma20, the\r\n    # old logic could place invalidation above entry and make risk/reward\r\n    # undefined.\r\n    if not math.isnan(ma20) and ma20 > 0 and ma20 <= close:\r\n        support_levels.append(ma20 * 0.985)\r\n    if not math.isnan(low10) and low10 > 0:\r\n        support_levels.append(low10 * 0.995)\r\n    if profile and profile.trend_policy == \"repair_rebound\" and not math.isnan(low20) and low20 > 0:\r\n        support_levels.append(low20 * 0.995)\r\n    return round(max(valid_numbers(support_levels) or [close * 0.92]), 2)\r\n\r\n\r\ndef candidate_base_upside(candidate: dict[str, Any], profile: FilterProfile | None = None) -> float:\r\n    score = float(candidate.get(\"score\") or 0.0)\r\n    vcp_classification = clean_text(safe_dict(candidate.get(\"vcp\")).get(\"classification\"))\r\n    acceleration = safe_dict(candidate.get(\"acceleration\"))\r\n    base_up = 0.06 if score >= 80 else 0.04\r\n    if vcp_classification == \"strict_vcp\":\r\n        base_up += 0.03\r\n    elif vcp_classification == \"near_vcp\":\r\n        base_up += 0.02\r\n    if acceleration.get(\"fundamental_acceleration_pass\"):\r\n        base_up += 0.01\r\n    if profile and candidate and catalyst_policy_pass(candidate, profile):\r\n        base_up += 0.01\r\n    if profile and profile.trend_policy == \"repair_rebound\":\r\n        base_up = max(base_up, 0.07)\r\n        return min(base_up, 0.14)\r\n    return min(base_up, 0.12)\r\n\r\n\r\ndef price_paths(candidate: dict[str, Any], request: dict[str, Any], profile: FilterProfile | None = None) -> dict[str, Any]:\r\n    metrics = safe_dict(candidate.get(\"metrics\"))\r\n    close = float(metrics.get(\"close\") or 0.0)\r\n    ma50 = float(metrics.get(\"ma50\") or close)\r\n    target_date = clean_text(request.get(\"target_date\"))\r\n    base_up = candidate_base_upside(candidate, profile)\r\n    optimistic_up = base_up + 0.05\r\n    pessimistic_down = 0.06\r\n    invalidation_level = candidate_invalidation_level(candidate, profile)\r\n    if profile and profile.trend_policy == \"repair_rebound\":\r\n        optimistic_up = base_up + 0.05\r\n        pessimistic_down = 0.05\r\n    return {\r\n        \"target_date\": target_date,\r\n        \"optimistic\": {\"range\": ordered_price_range(close * (1 + optimistic_up), close * (1 + optimistic_up + 0.03)), \"triggers\": [\"price expands with volume\", \"catalyst confirms\"]},\r\n        \"base\": {\"range\": ordered_price_range(close * (1 + base_up * 0.5), close * (1 + base_up)), \"triggers\": [\"trend holds above short averages\"]},\r\n        \"pessimistic\": {\"range\": ordered_price_range(max(close * (1 - pessimistic_down), ma50 * 0.97), close * (1 - pessimistic_down * 0.4)), \"triggers\": [\"trend loses short support\", \"catalyst disappoints\"]},\r\n        \"upgrade_triggers\": [\"close stays above 20-day average\", \"volume confirms breakout\"],\r\n        \"downgrade_triggers\": [\"close slips back below 20-day average\", \"catalyst loses credibility\"],\r\n        \"invalidation_condition\": f\"close loses key support near {invalidation_level}\",\r\n    }\r\n\r\n\r\ndef trade_card(candidate: dict[str, Any], profile: FilterProfile | None = None) -> dict[str, Any]:\r\n    metrics = safe_dict(candidate.get(\"metrics\"))\r\n    close = float(metrics.get(\"close\") or 0.0)\r\n    ma20 = float(metrics.get(\"ma20\") or close)\r\n    ma50 = float(metrics.get(\"ma50\") or close)\r\n    theme_low = max(close * 0.98, min(close, ma20 * 1.01))\r\n    theme_high = min(close * 1.01, max(close, ma20 * 1.03))\r\n    if profile and profile.trend_policy == \"repair_rebound\":\r\n        confirm_low = max(close * 1.01, theme_high, ma50 * 0.995)\r\n        confirm_high = max(confirm_low, max(close * 1.05, ma50 * 1.03))\r\n    else:\r\n        confirm_low = max(close * 1.005, theme_high)\r\n        confirm_high = max(confirm_low, close * 1.04)\r\n    trim_low = max(close * 1.06, confirm_high)\r\n    trim_high = max(trim_low, close * 1.10)\r\n    invalidation_level = candidate_invalidation_level(candidate, profile)\r\n    # For earnings-driven profiles, the technical invalidation does not\r\n    # capture event gap risk (e.g. a -15% gap on a disappointing preview).\r\n    # Surface an explicit warning so the user does not mistake the R/R ratio\r\n    # for a complete risk picture.\r\n    event_gap_risk_note = \"\"\r\n    if profile and profile.catalyst_policy == \"earnings_only\":\r\n        event_gap_risk_note = (\r\n            \"Event gap risk NOT included in invalidation level. \"\r\n            \"Earnings/preview announcements can gap beyond the technical stop. \"\r\n            \"Consider sizing down or using option hedges around the event date.\"\r\n        )\r\n    card: dict[str, Any] = {\r\n        \"theme_entry\": ordered_price_range(theme_low, theme_high),\r\n        \"confirmation_zone\": ordered_price_range(confirm_low, confirm_high),\r\n        \"trim_reduce_zone\": ordered_price_range(trim_low, trim_high),\r\n        \"invalidation_level\": invalidation_level,\r\n        \"failure_condition\": f\"price breaks below {invalidation_level} with failed catalyst follow-through\",\r\n        \"price_as_of\": clean_text(safe_dict(candidate.get(\"metrics\")).get(\"trade_date\")) or \"\",\r\n    }\r\n    if event_gap_risk_note:\r\n        card[\"event_gap_risk_note\"] = event_gap_risk_note\r\n    return card\r\n\r\n\r\ndef risk_reward_summary(candidate: dict[str, Any], request: dict[str, Any], profile: FilterProfile) -> dict[str, Any]:\r\n    paths = price_paths(candidate, request, profile)\r\n    card = trade_card(candidate, profile)\r\n    entry = midpoint(safe_list(card.get(\"theme_entry\")))\r\n"}}
