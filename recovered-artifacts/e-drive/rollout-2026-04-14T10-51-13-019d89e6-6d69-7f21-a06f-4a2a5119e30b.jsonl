\": _json_safe_value(metrics.get(\"atr_14\")),\n+        \"atr_pct_14\": _json_safe_value(metrics.get(\"atr_pct_14\")),\n+        \"gap_pct\": _json_safe_value(metrics.get(\"gap_pct\")),\n+        \"close_position_in_range\": _json_safe_value(metrics.get(\"close_position_in_range\")),\n+        \"distance_from_20d_high_pct\": _json_safe_value(metrics.get(\"distance_from_20d_high_pct\")),\n+        \"daily_return_pct\": _json_safe_value(metrics.get(\"daily_return_pct\")),\n+        \"high_20d\": _json_safe_value(metrics.get(\"high20_prev\")),\n+    }\n+    candidate[\"execution_metrics\"] = execution_metrics\n+    return execution_metrics\n+\n+\n+def compute_tape_signals(metrics: dict[str, Any]) -> dict[str, Any]:\n+    volume_ratio = _safe_float(metrics.get(\"volume_ratio_vs_20d\"))\n+    close = _safe_float(metrics.get(\"close\"))\n+    high20 = _safe_float(metrics.get(\"high20_prev\"))\n+    amplitude = _safe_float(metrics.get(\"amplitude\"))\n+    close_pos = _safe_float(metrics.get(\"close_position_in_range\"))\n+    gap_pct = _safe_float(metrics.get(\"gap_pct\"))\n+    ma20 = _safe_float(metrics.get(\"ma20\"))\n+    near_ma20 = not math.isnan(close) and not math.isnan(ma20) and ma20 > 0 and abs((close / ma20) - 1.0) <= 0.02\n+    return {\n+        \"volume_breakout\": _build_signal(\n+            not math.isnan(volume_ratio) and volume_ratio > 1.5 and not math.isnan(high20) and close > high20,\n+            \"volume_ratio_vs_20d > 1.5 and close > prior_20d_high\",\n+            {\"volume_ratio_vs_20d\": volume_ratio, \"close\": close, \"high_20d\": high20},\n+        ),\n+        \"volume_stall\": _build_signal(\n+            not math.isnan(volume_ratio) and volume_ratio > 1.5 and not math.isnan(amplitude) and amplitude > 0.03 and not math.isnan(close_pos) and close_pos < 0.3,\n+            \"volume_ratio_vs_20d > 1.5 and amplitude > 3% and close_position_in_range < 0.3\",\n+            {\"volume_ratio_vs_20d\": volume_ratio, \"amplitude\": amplitude, \"close_position_in_range\": close_pos},\n+        ),\n+        \"low_volume_pullback\": _build_signal(\n+            not math.isnan(volume_ratio) and volume_ratio < 0.6 and near_ma20,\n+            \"volume_ratio_vs_20d < 0.6 and close is within +/-2% of sma20\",\n+            {\"volume_ratio_vs_20d\": volume_ratio, \"close\": close, \"ma20\": ma20},\n+        ),\n+        \"high_open_low_close\": _build_signal(\n+            not math.isnan(gap_pct) and gap_pct > 0.01 and not math.isnan(close_pos) and close_pos < 0.25,\n+            \"gap_pct > 1% and close_position_in_range < 0.25\",\n+            {\"gap_pct\": gap_pct, \"close_position_in_range\": close_pos},\n+        ),\n+        \"low_open_high_close\": _build_signal(\n+            not math.isnan(gap_pct) and gap_pct < -0.005 and not math.isnan(close_pos) and close_pos > 0.75,\n+            \"gap_pct < -0.5% and close_position_in_range > 0.75\",\n+            {\"gap_pct\": gap_pct, \"close_position_in_range\": close_pos},\n+        ),\n+    }\n+\n+\n+def compute_momentum_flags(metrics: dict[str, Any], candidate: dict[str, Any]) -> dict[str, Any]:\n+    rows = safe_list(metrics.get(\"rows\"))\n+    closes = [_safe_float(item.get(\"close\")) for item in rows]\n+    returns = _daily_return_series(closes)\n+    recent_3 = returns[-3:]\n+    close = _safe_float(metrics.get(\"close\"))\n+    ma10 = _safe_float(metrics.get(\"ma10\"))\n+    ma20 = _safe_float(metrics.get(\"ma20\"))\n+    ma50 = _safe_float(metrics.get(\"ma50\"))\n+    ma150 = _safe_float(metrics.get(\"ma150\"))\n+    rsi14 = _safe_float(metrics.get(\"rsi14\"))\n+    gain_5d = (close / closes[-6] - 1.0) if len(closes) >= 6 and not math.isnan(close) and not math.isnan(closes[-6]) and closes[-6] > 0 else float(\"nan\")\n+    entry_reference = _resolve_entry_reference(candidate)\n+    distance_from_entry = (close - entry_reference) / entry_reference if not math.isnan(close) and not math.isnan(entry_reference) and entry_reference > 0 else float(\"nan\")\n+    return {\n+        \"trend_continuation\": _build_signal(\n+            not any(math.isnan(value) for value in (ma20, ma50, ma150, rsi14, close, ma10))\n+            and ma20 > ma50 > ma150\n+            and 50.0 <= rsi14 <= 70.0\n+            and close > ma10,\n+            \"sma20 > sma50 > sma150 and 50 <= rsi14 <= 70 and close > sma10\",\n+            {\"ma10\": ma10, \"ma20\": ma20, \"ma50\": ma50, \"ma150\": ma150, \"rsi14\": rsi14, \"close\": close},\n+        ),\n+        \"end_stage_acceleration\": _build_signal(\n+            (len(recent_3) == 3 and all(not math.isnan(value) and value > 0.03 for value in recent_3))\n+            or (not math.isnan(gain_5d) and gain_5d > 0.15 and not math.isnan(rsi14) and rsi14 > 80.0),\n+            \"3 consecutive daily gains > 3% or 5d gain > 15% with rsi14 > 80\",\n+            {\"recent_3_daily_returns\": recent_3, \"gain_5d\": gain_5d, \"rsi14\": rsi14},\n+        ),\n+        \"too_far_from_entry\": _build_signal(\n+            not math.isnan(distance_from_entry) and distance_from_entry > 0.15,\n+            \"distance_from_entry > 15%\",\n+            {\"entry_reference\": entry_reference, \"distance_from_entry\": distance_from_entry},\n+        ),\n+        \"high_consensus_chase\": _build_signal(\n+            not math.isnan(gain_5d) and gain_5d > 0.20,\n+            \"5d gain > 20%\",\n+            {\"gain_5d\": gain_5d},\n+        ),\n+    }\n+\n+\n+def compute_wyckoff_flags(metrics: dict[str, Any], rows: list[dict[str, Any]]) -> dict[str, Any]:\n+    volume_ratio = _safe_float(metrics.get(\"volume_ratio_vs_20d\"))\n+    close_pos = _safe_float(metrics.get(\"close_position_in_range\"))\n+    close = _safe_float(metrics.get(\"close\"))\n+    prev_close = _safe_float(metrics.get(\"prev_close\"))\n+    amplitude = _safe_float(metrics.get(\"amplitude\"))\n+    high20 = _safe_float(metrics.get(\"high20_prev\"))\n+    daily_return_pct = _safe_float(metrics.get(\"daily_return_pct\"))\n+    latest_high = _safe_float(rows[-1].get(\"high\")) if rows else float(\"nan\")\n+    recent_volume_ratios = _recent_volume_ratios(rows, count=3, lookback=20)\n+    recent_amplitudes = _recent_amplitudes(rows, count=3)\n+    avg_recent_volume_ratio = _mean_or_nan(recent_volume_ratios)\n+    avg_recent_amplitude = _mean_or_nan(recent_amplitudes)\n+    return {\n+        \"volume_thrust_up\": _build_signal(\n+            not math.isnan(volume_ratio) and volume_ratio > 2.0 and not math.isnan(close_pos) and close_pos > 0.7 and not math.isnan(close) and not math.isnan(prev_close) and close > prev_close,\n+            \"volume_ratio_vs_20d > 2.0 and close_position_in_range > 0.7 and close > prev_close\",\n+            {\"volume_ratio_vs_20d\": volume_ratio, \"close_position_in_range\": close_pos, \"close\": close, \"prev_close\": prev_close},\n+        ),\n+        \"low_volume_consolidation\": _build_signal(\n+            not math.isnan(avg_recent_volume_ratio) and avg_recent_volume_ratio < 0.7 and not math.isnan(avg_recent_amplitude) and avg_recent_amplitude < 0.02,\n+            \"3d average volume_ratio < 0.7 and 3d average amplitude < 2%\",\n+            {\"avg_volume_ratio_3d\": avg_recent_volume_ratio, \"avg_amplitude_3d\": avg_recent_amplitude},\n+        ),\n+        \"climax_reversal\": _build_signal(\n+            not math.isnan(volume_ratio) and volume_ratio > 2.0 and not math.isnan(amplitude) and amplitude > 0.05 and not math.isnan(close_pos) and close_pos < 0.3,\n+            \"volume_ratio_vs_20d > 2.0 and amplitude > 5% and close_position_in_range < 0.3\",\n+            {\"volume_ratio_vs_20d\": volume_ratio, \"amplitude\": amplitude, \"close_position_in_range\": close_pos},\n+        ),\n+        \"false_breakout\": _build_signal(\n+            not math.isnan(latest_high) and not math.isnan(high20) and latest_high > high20 and not math.isnan(close) and close < high20 and not math.isnan(volume_ratio) and volume_ratio > 1.2,\n+            \"intraday high > prior_20d_high and close < prior_20d_high and volume_ratio_vs_20d > 1.2\",\n+            {\"intraday_high\": latest_high, \"high_20d\": high20, \"close\": close, \"volume_ratio_vs_20d\": volume_ratio},\n+        ),\n+        \"strong_close_unchaseable\": _build_signal(\n+            not math.isnan(close_pos) and close_pos > 0.9 and not math.isnan(daily_return_pct) and daily_return_pct > 0.05 and not math.isnan(volume_ratio) and volume_ratio > 2.0,\n+            \"close_position_in_range > 0.9 and daily_return_pct > 5% and volume_ratio_vs_20d > 2.0\",\n+            {\"close_position_in_range\": close_pos, \"daily_return_pct\": daily_return_pct, \"volume_ratio_vs_20d\": volume_ratio},\n+        ),\n+    }\n+\n+\n+def _signal_triggered(bundle: dict[str, Any], key: str) -> bool:\n+    return bool(safe_dict(bundle.get(key)).get(\"triggered\"))\n+\n+\n+def _execution_liquidity_score(execution_metrics: dict[str, Any]) -> float:\n+    turnover = _safe_float(execution_metrics.get(\"turnover_amount\"))\n+    avg_turnover = _safe_float(execution_metrics.get(\"avg_turnover_20d\"))\n+    volume_ratio = _safe_float(execution_metrics.get(\"volume_ratio_vs_20d\"))\n+    true_turnover_rate = _safe_float(execution_metrics.get(\"true_turnover_rate\"))\n+    score = 0.0\n+    if not math.isnan(avg_turnover):\n+        if avg_turnover >= 1.5e9:\n+            score += 35.0\n+        elif avg_turnover >= 1.0e9:\n+            score += 28.0\n+        elif avg_turnover >= DEFAULT_MIN_AVG_TURNOVER_20D:\n+            score += 20.0\n+        elif avg_turnover >= DEFAULT_MIN_AVG_TURNOVER_20D * 0.6:\n+            score += 10.0\n+    if not math.isnan(turnover):\n+        if turnover >= 1.5e9:\n+            score += 30.0\n+        elif turnover >= 1.0e9:\n+            score += 24.0\n+        elif turnover >= DEFAULT_MIN_AVG_TURNOVER_20D:\n+            score += 16.0\n+        elif turnover >= DEFAULT_MIN_AVG_TURNOVER_20D * 0.6:\n+            score += 8.0\n+    if not math.isnan(volume_ratio):\n+        if 0.8 <= volume_ratio <= 2.5:\n+            score += 20.0\n+        elif 0.6 <= volume_ratio <= 3.5:\n+            score += 12.0\n+        elif volume_ratio > 0:\n+            score += 4.0\n+    if not math.isnan(true_turnover_rate):\n+        if 0.01 <= true_turnover_rate <= 0.08:\n+            score += 10.0\n+        elif true_turnover_rate > 0:\n+            score += 5.0\n+    return round(_clamp(score, 0.0, 100.0), 2)\n+\n+\n+def _execution_volatility_score(execution_metrics: dict[str, Any]) -> float:\n+    atr_pct = _safe_float(execution_metrics.get(\"atr_pct_14\"))\n+    volatility_20d = _safe_float(execution_metrics.get(\"volatility_20d\"))\n+    amplitude = _safe_float(execution_metrics.get(\"amplitude\"))\n+    score = 100.0\n+    if not math.isnan(atr_pct):\n+        if atr_pct > 0.08:\n+            score -= 45.0\n+        elif atr_pct > 0.05:\n+            score -= 25.0\n+        elif atr_pct > 0.03:\n+            score -= 10.0\n+    if not math.isnan(volatility_20d):\n+        if volatility_20d > 0.06:\n+            score -= 35.0\n+        elif volatility_20d > 0.04:\n+            score -= 20.0\n+        elif volatility_20d > 0.02:\n+            score -= 10.0\n+    if not math.isnan(amplitude):\n+        if amplitude > 0.06:\n+            score -= 10.0\n+        elif amplitude > 0.04:\n+            score -= 5.0\n+    return round(_clamp(score, 0.0, 100.0), 2)\n+\n+\n+def _execution_gap_risk_score(execution_metrics: dict[str, Any], tape: dict[str, Any], wyckoff: dict[str, Any]) -> float:\n+    gap_pct = abs(_safe_float(execution_metrics.get(\"gap_pct\")))\n+    score = 100.0\n+    if not math.isnan(gap_pct):\n+        if gap_pct > 0.08:\n+            score -= 70.0\n+        elif gap_pct > 0.05:\n+            score -= 45.0\n+        elif gap_pct > 0.03:\n+            score -= 25.0\n+        elif gap_pct > 0.02:\n+            score -= 10.0\n+    if _signal_triggered(tape, \"high_open_low_close\"):\n+        score -= 15.0\n+    if _signal_triggered(wyckoff, \"strong_close_unchaseable\"):\n+        score -= 10.0\n+    return round(_clamp(score, 0.0, 100.0), 2)\n+\n+\n+def _execution_confirmation_quality(tape: dict[str, Any], momentum: dict[str, Any], wyckoff: dict[str, Any]) -> float:\n+    score = 50.0\n+    score += 18.0 if _signal_triggered(tape, \"volume_breakout\") else 0.0\n+    score += 8.0 if _signal_triggered(tape, \"low_volume_pullback\") else 0.0\n+    score += 10.0 if _signal_triggered(tape, \"low_open_high_close\") else 0.0\n+    score += 12.0 if _signal_triggered(momentum, \"trend_continuation\") else 0.0\n+    score += 10.0 if _signal_triggered(wyckoff, \"volume_thrust_up\") else 0.0\n+    score += 7.0 if _signal_triggered(wyckoff, \"low_volume_consolidation\") else 0.0\n+    score -= 18.0 if _signal_triggered(tape, \"volume_stall\") else 0.0\n+    score -= 12.0 if _signal_triggered(tape, \"high_open_low_close\") else 0.0\n+    score -= 14.0 if _signal_triggered(momentum, \"end_stage_acceleration\") else 0.0\n+    score -= 12.0 if _signal_triggered(momentum, \"too_far_from_entry\") else 0.0\n+    score -= 10.0 if _signal_triggered(momentum, \"high_consensus_chase\") else 0.0\n+    score -= 16.0 if _signal_triggered(wyckoff, \"climax_reversal\") else 0.0\n+    score -= 14.0 if _signal_triggered(wyckoff, \"false_breakout\") else 0.0\n+    score -= 12.0 if _signal_triggered(wyckoff, \"strong_close_unchaseable\") else 0.0\n+    return round(_clamp(score, 0.0, 100.0), 2)\n+\n+\n+def compute_execution_composite_score(execution_metrics: dict[str, Any], tape: dict[str, Any], momentum: dict[str, Any], wyckoff: dict[str, Any]) -> float:\n+    liquidity_score = _execution_liquidity_score(execution_metrics)\n+    volatility_score = _execution_volatility_score(execution_metrics)\n+    gap_risk_score = _execution_gap_risk_score(execution_metrics, tape, wyckoff)\n+    confirmation_quality = _execution_confirmation_quality(tape, momentum, wyckoff)\n+    composite = (\n+        liquidity_score * 0.30\n+        + volatility_score * 0.15\n+        + gap_risk_score * 0.20\n+        + confirmation_quality * 0.35\n+    )\n+    return round(_clamp(composite, 0.0, 100.0), 2)\n+\n+\n+def _execution_elasticity_score(item: dict[str, Any]) -> float:\n+    execution_metrics = safe_dict(item.get(\"execution_metrics\"))\n+    tape = safe_dict(item.get(\"tape_signals\"))\n+    wyckoff = safe_dict(item.get(\"wyckoff_flags\"))\n+    momentum = safe_dict(item.get(\"momentum_flags\"))\n+    amplitude = _safe_float(execution_metrics.get(\"amplitude\"))\n+    atr_pct = _safe_float(execution_metrics.get(\"atr_pct_14\"))\n+    score = 0.0\n+    if not math.isnan(amplitude):\n+        if 0.02 <= amplitude <= 0.06:\n+            score += 35.0\n+        elif amplitude > 0.06:\n+            score += 20.0\n+    if not math.isnan(atr_pct):\n+        if 0.015 <= atr_pct <= 0.05:\n+            score += 25.0\n+        elif atr_pct > 0.05:\n+            score += 15.0\n+    score += 20.0 if _signal_triggered(tape, \"volume_breakout\") else 0.0\n+    score += 15.0 if _signal_triggered(wyckoff, \"volume_thrust_up\") else 0.0\n+    score += 5.0 if _signal_triggered(momentum, \"trend_continuation\") else 0.0\n+    return round(_clamp(score, 0.0, 100.0), 2)\n+\n+\n+def _build_leg_ranking_factors(item: dict[str, Any], composite_rank: int | None = None) -> dict[str, Any]:\n+    execution_metrics = safe_dict(item.get(\"execution_metrics\"))\n+    tape = safe_dict(item.get(\"tape_signals\"))\n+    momentum = safe_dict(item.get(\"momentum_flags\"))\n+    wyckoff = safe_dict(item.get(\"wyckoff_flags\"))\n+    return {\n+        \"liquidity_score\": _execution_liquidity_score(execution_metrics),\n+        \"volatility_score\": _execution_volatility_score(execution_metrics),\n+        \"gap_risk_score\": _execution_gap_risk_score(execution_metrics, tape, wyckoff),\n+        \"confirmation_quality\": _execution_confirmation_quality(tape, momentum, wyckoff),\n+        \"composite_rank\": composite_rank,\n+    }\n+\n+\n+def _build_leg_entry(item: dict[str, Any