ransition_watch = build_transition_watch(dropped_scored_raw, request, profile)\r\n    blocked_candidates = build_blocked_candidates(dropped_raw_for_focus, request)\r\n    focus_diagnostics = build_focus_diagnostics(kept, [*dropped_scored_raw, *dropped_raw_for_focus], request, profile)\r\n    failure_counts: dict[str, int] = {}\r\n    failure_categories: dict[str, int] = {\"screened_out\": 0, \"data_blocked\": 0, \"board_scope_excluded\": 0}\r\n    for item in dropped:\r\n        reason = failure_reason_bucket(clean_text(item.get(\"drop_reason\")))\r\n        failure_counts[reason] = failure_counts.get(reason, 0) + 1\r\n        cat = failure_category(clean_text(item.get(\"drop_reason\")))\r\n        failure_categories[cat] = failure_categories.get(cat, 0) + 1\r\n    # --- Degraded mode detection ---\r\n    has_universe_fetch_failure = bool(universe_fetch_warning(request))\r\n    has_seeded_universe = bool(safe_list(request.get(\"universe_candidates\")))\r\n    if has_universe_fetch_failure and not has_seeded_universe:\r\n        degraded_mode = True\r\n        degradation_reason = \"provider_blocked\"\r\n        result_scope = \"focus_tickers_only\"\r\n    elif has_seeded_universe:\r\n        degraded_mode = False\r\n        degradation_reason = \"\"\r\n        result_scope = \"seeded_candidates_only\"\r\n    else:\r\n        degraded_mode = False\r\n        degradation_reason = \"\"\r\n        result_scope = \"full_universe\"\r\n    # --- Leg mapping from top picks ---\r\n    leg_mapping = {\r\n        \"primary_leg\": clean_text(top_picks[0].get(\"name\")) if len(top_picks) >= 1 else None,\r\n        \"confirm_leg\": clean_text(top_picks[1].get(\"name\")) if len(top_picks) >= 2 else None,\r\n        \"hedge_leg\": None,\r\n        \"mapping_basis\": \"shortlist_score_rank\",\r\n        \"as_of\": clean_text(request.get(\"analysis_date\")),\r\n    }\r\n    result = {\r\n        \"status\": \"ok\",\r\n        \"workflow_kind\": \"month_end_shortlist\",\r\n        \"degraded_mode\": degraded_mode,\r\n        \"degradation_reason\": degradation_reason,\r\n        \"result_scope\": result_scope,\r\n        \"request\": request,\r\n        \"universe_summary\": {\r\n            \"universe_size\": len(universe),\r\n            \"eligible_size\": len(eligible),\r\n            \"working_set_size\": len(working_set),\r\n            \"snapshot_size\": len(snapshots),\r\n            \"kept_count\": len(kept),\r\n            \"failure_counts\": failure_counts,\r\n            \"failure_categories\": failure_categories,\r\n        },\r\n        \"filter_summary\": {\r\n            \"filter_profile\": profile.name,\r\n            \"shortlist_keep_line\": profile.shortlist_keep_line,\r\n            \"top_pick_keep_line\": profile.top_pick_keep_line,\r\n            \"top_pick_selection_mode\": top_pick_selection_mode if top_picks or top_pick_selection_mode == \"x_style_core_required_no_match\" else \"\",\r\n            \"requested_working_set_limit\": int(request.get(\"working_set_limit\", 0) or 0),\r\n            \"effective_working_set_limit\": effective_working_set_limit,\r\n            \"history_retry_candidate_count\": len(retry_candidates),\r\n            \"history_retry_recovered_count\": history_retry_recovered_count,\r\n            \"history_retry_remaining_count\": history_retry_remaining_count,\r\n            \"blocked_candidate_count\": len(blocked_candidates),\r\n            \"benchmark_fetch_error\": benchmark_fetch_error,\r\n        },\r\n        \"scorecard\": [shortlist_record(candidate) for candidate in kept],\r\n        \"kept\": [shortlist_record(candidate) for candidate in kept],\r\n        \"dropped\": dropped,\r\n        \"top_picks\": top_picks,\r\n"}}
{"timestamp":"2026-04-14T02:56:57.317Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_eIna4etiOx4ERKGDP07e2KuK","output":"Exit code: 0\nWall time: 0.5 seconds\nOutput:\n\r\nKeep only names that can be written into a concrete plan:\r\n\r\n- why enter now\r\n- what exactly makes the thesis wrong\r\n- what would make us downgrade the setup\r\n- where to reduce if the move becomes crowded\r\n\r\nIf these cannot be written, drop the stock.\r\n\r\n### From turtle / trend-following discipline\r\n\r\nUse as a caution layer:\r\n\r\n- if volatility is too high relative to the intended stop, size must shrink\r\n- if that makes the trade impractical, drop it\r\n- do not fake precision on a name whose volatility makes execution sloppy\r\n\r\n## Preferred Setup Types\r\n\r\nFor month-end A-share filtering, prioritize:\r\n\r\n1. `leadership continuation`\r\n   - strong theme, strong tape, catalyst still ahead\r\n2. `failed breakdown repair`\r\n   - stock stopped going down, reclaimed a key level, catalyst pending\r\n3. `oversold rebound with hard catalyst`\r\n   - only if the catalyst is near and invalidation is clear\r\n4. `late-cycle breakout`\r\n   - only if not already too extended\r\n\r\n## Default Exclusions\r\n\r\nDrop by default:\r\n\r\n"}}
{"timestamp":"2026-04-14T02:56:57.317Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_4v8cVAibKtJPEBcCpF3aUSvw","output":"Exit code: 0\nWall time: 0.5 seconds\nOutput:\nfrom __future__ import annotations\r\n\r\nimport json\r\nimport shutil\r\nimport sys\r\nimport unittest\r\nfrom datetime import date, timedelta\r\nfrom pathlib import Path\r\nfrom unittest.mock import patch\r\n\r\n\r\nSCRIPT_DIR = (\r\n    Path(__file__).resolve().parents[1]\r\n    / \"financial-analysis\"\r\n    / \"skills\"\r\n    / \"month-end-shortlist\"\r\n    / \"scripts\"\r\n)\r\nif str(SCRIPT_DIR) not in sys.path:\r\n    sys.path.insert(0, str(SCRIPT_DIR))\r\n\r\nfrom month_end_shortlist_runtime import (\r\n    FILTER_PROFILES,\r\n    LIMIT_UP_THRESHOLDS,\r\n    OVERNIGHT_CATALYST_ADJUSTMENT_CAP_LOWER,\r\n    OVERNIGHT_CATALYST_ADJUSTMENT_CAP_UPPER,\r\n    OVERNIGHT_EARNINGS_SURPRISE_BONUS_BASE,\r\n    OVERNIGHT_EARNINGS_SURPRISE_YOY_STEP,\r\n    OVERNIGHT_EARNINGS_SURPRISE_YOY_THRESHOLD,\r\n    PREV_DAY_LIMIT_UP_BASE_PENALTY,\r\n    PREV_DAY_LIMIT_UP_ADVERSE_MULTIPLIER,\r\n    PREV_DAY_LIMIT_UP_SELECTIVE_MULTIPLIER,\r\n    STRUCTURED_EVENT_KEYWORDS,\r\n    THEME_DECAY_FACTOR_LIMIT_UP,\r\n    active_theme_rules,\r\n    acceleration_summary,\r\n    build_score_components,\r\n    build_markdown_report,\r\n    build_transition_watch,\r\n    candidate_matches_x_style_theme,\r\n    catalyst_policy_pass,\r\n    classify_overnight_events,\r\n    classify_vcp,\r\n    compute_candidate_snapshot,\r\n    default_working_set_limit,\r\n    defensive_growth_tilt,\r\n    extract_10jqka_trade_calendar_events,\r\n    extract_percentage_series,\r\n    extract_structured_events_from_text,\r\n    fetch_stockstar_summary_fundamentals,\r\n    fetch_stockstar_fundamentals,\r\n    fetch_tencent_qfq_history_rows,\r\n    fetch_history_rows,\r\n    fallback_structured_events,\r\n    apply_working_set_limit,\r\n    is_prev_day_limit_up,\r\n    merge_fundamental_payloads,\r\n    normalize_request,\r\n    normalize_x_style_overlay,\r\n    failure_reason_bucket,\r\n    failure_category,\r\n    overnight_catalyst_adjustment,\r\n    overlay_score_adjustment,\r\n    resolve_fundamentals,\r\n    resolve_structured_events,\r\n    retryable_history_exception,\r\n    run_month_end_shortlist,\r\n    price_paths,\r\n    repair_rebound_summary,\r\n    risk_reward_summary,\r\n    should_use_ratio_rs,\r\n    strip_html_tags,\r\n    structured_catalyst_summary,\r\n    theme_alignment_summary,\r\n    top_pick_gaps,\r\n    top_pick_selection_bucket,\r\n    total_score,\r\n    trade_card,\r\n    trend_template_flags,\r\n    trend_template_pass,\r\n    x_style_overlay_adjustment,\r\n)\r\n\r\n\r\ndef build_history(\r\n    *,\r\n    start: date,\r\n    days: int = 470,\r\n    start_close: float = 50.0,\r\n    daily_step: float = 0.18,\r\n    amount: float = 9e8,\r\n    volume: float = 1_000_000.0,\r\n    mode: str = \"strict_vcp\",\r\n) -> list[dict[str, float | str]]:\r\n    rows: list[dict[str, float | str]] = []\r\n    close = start_close\r\n    strict_start = days - 45\r\n    near_start = days - 30\r\n    for offset in range(days):\r\n        trade_date = start + timedelta(days=offset)\r\n        close += daily_step\r\n        if offset % 7 == 0:\r\n            close -= daily_step * 0.6\r\n        high = close * 1.02\r\n        low = close * 0.98\r\n        vol = volume\r\n        amt = amount\r\n        if mode in {\"strict_vcp\", \"near_vcp\"} and offset >= (strict_start if mode == \"strict_vcp\" else near_start):\r\n            remaining = days - offset\r\n            if mode == \"strict_vcp\":\r\n                block = min((offset - strict_start) // 10, 3)\r\n                amplitudes = [0.18, 0.12, 0.08, 0.05]\r\n                volume_factors = [1.2, 1.0, 0.75, 0.40]\r\n                amp = amplitudes[block]\r\n                high = close * (1 + amp / 2)\r\n                low = close * (1 - amp / 2)\r\n                vol = volume * volume_factors[block]\r\n                amt = amount * volume_factors[block]\r\n                if remaining <= 5:\r\n                    close = max(close, rows[-1][\"high\"] * 1.01)\r\n                    high = close * 1.01\r\n                    low = close * 0.995\r\n                    vol = volume * 1.8\r\n                    amt = amount * 1.7\r\n            else:\r\n                block = (offset - near_start) // 10\r\n                amplitudes = [0.18, 0.13, 0.10]\r\n                volume_factors = [1.0, 0.8, 0.65]\r\n                if offset % 3 == 0:\r\n                    close -= daily_step * 2.2\r\n                amp = amplitudes[block]\r\n                high = close * (1 + amp / 2)\r\n                low = close * (1 - amp / 2)\r\n                vol = volume * volume_factors[block]\r\n                amt = amount * volume_factors[block]\r\n        elif mode == \"broken\":\r\n            if offset > days - 80:\r\n                close -= 0.35\r\n            high = close * 1.01\r\n            low = close * 0.97\r\n            amt = amount * 0.7\r\n            vol = volume * 0.7\r\n        rows.append(\r\n            {\r\n                \"trade_date\": trade_date.isoformat(),\r\n                \"open\": close,\r\n                \"high\": high,\r\n                \"low\": low,\r\n                \"close\": close,\r\n                \"vol\": vol,\r\n                \"amount\": amt,\r\n                \"pct_chg\": 0.0,\r\n            }\r\n        )\r\n    return rows\r\n\r\n\r\ndef build_repair_history(*, start: date, days: int = 470, amount: float = 9e8, volume: float = 1_000_000.0) -> list[dict[str, float | str]]:\r\n    rows: list[dict[str, float | str]] = []\r\n    close = 85.0\r\n    for offset in range(days):\r\n        trade_date = start + timedelta(days=offset)\r\n        if offset < days - 70:\r\n            close -= 0.12\r\n        else:\r\n            close += 0.32\r\n            if offset % 6 == 0:\r\n                close -= 0.08\r\n        high = close * 1.018\r\n        low = close * 0.982\r\n        rows.append(\r\n            {\r\n                \"trade_date\": trade_date.isoformat(),\r\n                \"open\": close,\r\n                \"high\": high,\r\n                \"low\": low,\r\n                \"close\": close,\r\n                \"vol\": volume,\r\n                \"amount\": amount,\r\n                \"pct_chg\": 0.0,\r\n            }\r\n        )\r\n    return rows\r\n\r\n\r\nclass MonthEndShortlistRuntimeTests(unittest.TestCase):\r\n    def test_main_board_only_excludes_chinext_and_star_without_whitelist(self) -> None:\r\n        request = {\r\n            \"analysis_time\": \"2026-04-07T00:00:00+00:00\",\r\n            \"target_date\": \"2026-04-30\",\r\n            \"live_fundamental_provider\": \"none\",\r\n            \"backtest_mode\": \"off\",\r\n            \"universe_candidates\": [\r\n                {\"ticker\": \"001309.SZ\", \"name\": \"еѓ∞йФЛжІСйНТ?, \"sector\": \"йНЧе©ВоЗ±жµ£?, \"price\": 30, \"turnover_amount\": 8e8, \"total_market_cap\": 2e11, \"free_float_market_cap\": 1.5e11},\r\n                {\"ticker\": \"300502.SZ\", \"name\": \"йПВзЙИжІЧйР©?, \"sector\": \"йЦЂж∞ЂдњКзТБжГІоШђ\", \"price\": 30, \"turnover_amount\": 8e8, \"total_market_cap\": 2e11, \"free_float_market_cap\": 1.5e11},\r\n                {\"ticker\": \"688313.SH\", \"name\": \"жµ†жЫЪеМ†йНПе§КзУЩ\", \"sector\": \"йЦЂж∞ЂдњКзТБжГІоШђ\", \"price\": 30, \"turnover_amount\": 8e8, \"total_market_cap\": 2e11, \"free_float_market_cap\": 1.5e11},\r\n            ],\r\n            \"history_by_ticker\": {\r\n                \"001309.SZ\": build_history(start=date(2025, 1, 1)),\r\n                \"300502.SZ\": build_history(start=date(2025, 1, 1)),\r\n                \"688313.SH\": build_history(start=date(2025, 1, 1)),\r\n                \"000300.SS\": build_history(start=date(2025, 1, 1), start_close=10.0, daily_step=0.03, mode=\"near_vcp\"),\r\n            },\r\n            \"structured_events_by_ticker\": {\r\n                \"001309.SZ\": [{\"event_type\": \"scheduled_earnings\", \"event_date\": \"2026-04-28\"}],\r\n                \"300502.SZ\": [{\"event_type\": \"scheduled_earnings\", \"event_date\": \"2026-04-24\"}],\r\n                \"688313.SH\": [{\"event_type\": \"scheduled_earnings\", \"event_date\": \"2026-04-18\"}],\r\n            },\r\n            \"fundamentals_by_ticker\": {\r\n                \"001309.SZ\": {\"latest_profit_yoy\": 60, \"latest_revenue_yoy\": 45, \"previous_profit_yoy\": 20, \"previous_revenue_yoy\": 10},\r\n            },\r\n        }\r\n        result = run_month_end_shortlist(request)\r\n        kept_tickers = {item[\"ticker\"] for item in result[\"kept\"]}\r\n        dropped_reasons = {item[\"ticker\"]: item[\"drop_reason\"] for item in result[\"dropped\"] if \"ticker\" in item}\r\n        self.assertIn(\"001309.SZ\", kept_tickers)\r\n        self.assertEqual(dropped_reasons[\"300502.SZ\"], \"chinext_not_whitelisted\")\r\n        self.assertEqual(dropped_reasons[\"688313.SS\"], \"star_board_excluded\")\r\n\r\n    def test_chinext_whitelist_allows_300_ticker(self) -> None:\r\n        request = {\r\n            \"analysis_time\": \"2026-04-07T00:00:00+00:00\",\r\n            \"target_date\": \"2026-04-30\",\r\n            \"chinext_whitelist\": [\"300502\"],\r\n            \"universe_candidates\": [\r\n                {\"ticker\": \"300502.SZ\", \"name\": \"йПВзЙИжІЧйР©?, \"sector\": \"йЦЂж∞ЂдњКзТБжГІоШђ\", \"price\": 30, \"turnover_amount\": 8e8, \"total_market_cap\": 2e11, \"free_float_market_cap\": 1.5e11},\r\n            ],\r\n            \"history_by_ticker\": {\r\n                \"300502.SZ\": build_history(start=date(2025, 1, 1)),\r\n                \"000300.SS\": build_history(start=date(2025, 1, 1), start_close=10.0, daily_step=0.03, mode=\"near_vcp\"),\r\n            },\r\n            \"structured_events_by_ticker\": {\r\n                \"300502.SZ\": [{\"event_type\": \"scheduled_earnings\", \"event_date\": \"2026-04-24\"}],\