 }\r\n\r\n  // Build the facts objects\r\n  const intradayFacts = command.mode === \"intraday\"\r\n    ? { trade_day: rawFacts.trade_day || null, as_of: rawFacts.as_of || new Date().toISOString(), fact_flags: rawFacts }\r\n    : (rawFacts._intraday || null);\r\n\r\n  const postcloseFacts = command.mode === \"postclose\"\r\n    ? {\r\n        trade_day: rawFacts.trade_day || null,\r\n        as_of: rawFacts.as_of || new Date().toISOString(),\r\n        fact_flags: rawFacts,\r\n        execution_result: rawFacts.execution_result || null,\r\n        missed_or_wrong_assumptions: rawFacts.missed_or_wrong_assumptions || []\r\n      }\r\n    : null;\r\n\r\n  // Run validation\r\n  writer.log(`=== DAILY VALIDATION (${command.mode}) ===`);\r\n  writer.log(\"\");\r\n\r\n  const record = runDailyValidation(exportData, {\r\n    mode: command.mode,\r\n    intradayFacts,\r\n    postcloseFacts,\r\n    xSignals\r\n  });\r\n\r\n  // Output\r\n  if (command.json) {\r\n    writer.log(JSON.stringify(record, null, 2));\r\n  } else {\r\n    const rendered = renderValidationRecord(record);\r\n    writer.log(rendered);\r\n  }\r\n\r\n  // Persist if requested\r\n  let jsonWritePath = null;\r\n  if (command.writeJson) {\r\n    const tradeDay = record.trade_day || formatDateStamp(new Date());\r\n    const datedPath = resolveDatedOutputJsonPath(command, config, tradeDay, command.mode);\r\n    const lastPath = resolveLastOutputJsonPath(command, config);\r\n\r\n    fs.mkdirSync(path.dirname(datedPath), { recursive: true });\r\n    const payload = `${JSON.stringify(record, null, 2)}\\n`;\r\n    fs.writeFileSync(datedPath, payload, \"utf8\");\r\n    fs.writeFileSync(lastPath, payload, \"utf8\");\r\n\r\n    jsonWritePath = datedPath;\r\n    writer.log(\"\");\r\n    writer.log(`json: ${path.relative(config.projectRoot, datedPath)}`);\r\n    writer.log(`last: ${path.relative(config.projectRoot, lastPath)}`);\r\n  }\r\n\r\n  return {\r\n    ...record,\r\n"}}
