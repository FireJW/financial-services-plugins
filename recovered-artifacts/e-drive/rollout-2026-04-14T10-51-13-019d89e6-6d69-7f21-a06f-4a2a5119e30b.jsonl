                f\"mae `{backtest.get('max_adverse_excursion')}`\"\r\n                )\r\n            if clean_text(price_map.get(\"invalidation_condition\")):\r\n                lines.append(f\"  invalidation note `{clean_text(price_map.get('invalidation_condition'))}`\")\r\n    return \"\\n\".join(lines).strip() + \"\\n\"\r\n\r\n\r\ndef run_month_end_shortlist(raw_request: dict[str, Any]) -> dict[str, Any]:\r\n    request = normalize_request(raw_request)\r\n    profile = normalize_filter_profile(request.get(\"filter_profile\"))\r\n    universe = resolve_universe_candidates(request)\r\n    eligible: list[dict[str, Any]] = []\r\n    dropped: list[dict[str, Any]] = []\r\n    dropped_raw_for_focus: list[dict[str, Any]] = []\r\n    for candidate in universe:\r\n        allowed, reason = keep_by_universe_rules(candidate, request)\r\n        if not allowed:\r\n            dropped_record = {\"ticker\": clean_text(candidate.get(\"ticker\")), \"name\": clean_text(candidate.get(\"name\")), \"drop_reason\": reason}\r\n            dropped.append(dropped_record)\r\n            dropped_raw_for_focus.append({**deepcopy(candidate), \"drop_reason\": reason})\r\n            continue\r\n        eligible.append(candidate)\r\n    effective_working_set_limit = default_working_set_limit(request, len(eligible))\r\n    working_set = apply_working_set_limit_with_focus(eligible, effective_working_set_limit)\r\n    benchmark_candidate = {\"ticker\": request[\"benchmark_ticker\"], \"code\": request[\"benchmark_ticker\"][:-3]}\r\n"}}
