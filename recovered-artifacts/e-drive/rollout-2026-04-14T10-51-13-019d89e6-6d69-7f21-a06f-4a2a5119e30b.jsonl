ОЫжЈЗжњЗеІҐйПИоДДеЩЊжґУеЇ°оЖРйЦњжђНвВђ?,\r\n        \"killSwitch\": \"жњ°еВЫзБЙе®СгД§зОѓе®МвДГжєБйПВжЭњоЦГйНПжИ†еєЗйКЖдљЈзЈµзЉБжђОжЕ®жЊґеґГвВђдљєеЮ®зФѓеВЪжЇАеЃЄеПЙељБйНУеґДж∞¶йПДжТєзєГжЊґ—ЗеДійНТеЧШжЂЩеІШжЧУзіЭзБПеПШзђЕзТЛеЖ®иДКйОђ—ЖеРЩй™ЮжЬµзі≠йНПе†ЬзєЪйР£жђУжІїзАєе†ЫвВђ?,\r\n        \"stance\": \"Howard MarksйФЫж∞ђзґЛйНУеґЖжІЄжґУоЕҐж£њйОђдЊКзіЭжґУеґЖжІЄйПЕоИЫзЪµе©КвА≤з≤®йРЪжґЩжХЊйОђдљµвВђеВЬоГЗжµЬе≤АзС™йПЗз£ЛоЗЪжµЉж®ЇеОЫйС∞еЖ≠ж™ї жґУоЕЮжµЧеЃЄгДІзЕґйФЫе±љжіЬжґУеУДзХ†йПЗз£ЛеЕШжЊґеЛ≠жВКе®СгД§зОѓжґУеґЕеЉЈж£∞еЛђжє°йОіж†¶зЈµзЉБжђОжЕ®жЊґеґГвВђ?\r\n      },\r\n      {\r\n        \"mentor\": \"Buffett\",\r\n        \"vote\": \"support\",\r\n        \"confidence\": 82,\r\n        \"confidenceLabel\": \"82/100\",\r\n        \"maxPosition\": \"жґУоЕЯжљЧзїЙжИЮе¶І 0.35 / жґУоЕЮжµЧеЃЄгДІзЕґ 0.10 / зАєењУжЛ∞зїЙжИЮе¶І 0.05\",\r\n        \"keyEvidence\": \"зСХдљЇжєЕзАєж∞ЂзОѓйПЙеЖ¶вВђдљєеЮЪйПИоДГжµЖзАЪдљЄжЛ∞жµЉдљЈзђЯзТРгД©еЩЇйФЫе≤ГвВђе±ЉзђЙйПДоИЪељІйР™еђ©й™ЗжґУж∞≠жЂЩеІШжЧАеЮ®е®СгД§зОѓйПБеСђз∞®йКЖ?,\r\n        \"killSwitch\": \"жњ°еВЫзБЙе®СгД§зОѓжµЉзК≤оЗ±жґУеґЕеЯМйНТвХВйЉОйФЫе±ЊеЮ®йС∞еСђзіТжґУж∞≠зЧЕйПИе§ЙзґШжµ†гГ§иіЯйР®еЛЂзХЊжµ†йФЛжљИйФЫе±љж∞®жґУеґИоЗЪйОµвХБгБЗжµ†жТ≤зґЕйКЖ?,\r\n        \"stance\": \"BuffettйФЫж∞ђељІйПИе§Мжє°еІЭпљЕеПњжЊґеЫІзХЊжµ†йФЛжљИйНЬе±ЊеЮЪйПИоДГжµЖзАЪдљљеЕШйНФжґЪжЃСйНПоДАеЊГйФЫе±ЊеҐ†йЦ∞еґЖеЮЪжґУ?жґУоЕЯжљЧзїЙжИЮе¶ІйФЫжґШеПЊжµ£жђРзИ£йР®еЛђжЄґжЊґж∞≠жІЄйПЕоИЫзЪµеѓЃиІДвВђ—Вз≤®йКЖ?\r\n      }\r\n    ]\r\n  },\r\n  \"stages\": [\r\n    {\r\n      \"key\": \"workbench_v3\",\r\n      \"title\": \"Workbench v3\",\r\n      \"mode\": \"local-fallback\",\r\n      \"noteTitles\": [\r\n        \"Legendary-Investor-Workbench-v3\",\r\n        \"Legendary-Investor-Mentor-Query-Console\"\r\n      ],\r\n      \"output\": \"йПИоДАжєійНЪеЇ°оШђе¶ѓвА≥зі°йФЫж∞ђзґЛйНУеґЖжіњйНН?жЄЪжґҐжЄґйНЫгД¶жє°жµЬгВЖжІЧеЃЄгГ§зґФйНЩиИђвВђдњУn\\n- йРШиИµвВђдљЄеЮљйПВоЕ®зі∞жЭ©жђРжІЄе®СгД§зОѓжґУеЇЭзЈµйЧЗвВђж•†е≤ГзШЙйЧВоЗАоХљйФЫе±ЉзђЙйПДоИЪеіЯзїЊ?headline жµЬгВЖжІЧйФЫжґЩжіњйНПжКљжХ≠йР®еЛђжІЄе®СгД§зОѓйПДоИЪжГБй