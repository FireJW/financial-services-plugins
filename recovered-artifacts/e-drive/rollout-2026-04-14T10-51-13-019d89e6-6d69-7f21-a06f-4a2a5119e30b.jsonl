{"timestamp":"2026-04-14T03:29:18.459Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_117vHhiSndo9FvAMX0hhaRZA","output":"Exit code: 0\nWall time: 0.5 seconds\nOutput:\n            result[index] = 100.0\r\n            continue\r\n        rs = avg_gain / avg_loss\r\n        result[index] = 100.0 - (100.0 / (1.0 + rs))\r\n    return result\r\n\r\n\r\ndef compute_price_metrics(rows: list[dict[str, Any]]) -> dict[str, Any]:\r\n    closes = [float(row.get(\"close\") or float(\"nan\")) for row in rows]\r\n    highs = [float(row.get(\"high\") or float(\"nan\")) for row in rows]\r\n    lows = [float(row.get(\"low\") or float(\"nan\")) for row in rows]\r\n    volumes = [float(row.get(\"vol\") or float(\"nan\")) for row in rows]\r\n    amounts = [float(row.get(\"amount\") or float(\"nan\")) for row in rows]\r\n\r\n    ma20 = sma(closes, 20)\r\n    ma50 = sma(closes, 50)\r\n    ma150 = sma(closes, 150)\r\n    ma200 = sma(closes, 200)\r\n    vol_ma20 = sma(volumes, 20)\r\n    rsi14 = rsi(closes, 14)\r\n\r\n    high52 = max(valid_numbers(highs[-252:]) or valid_numbers(highs) or [float(\"nan\")])\r\n    low52 = min(valid_numbers(lows[-252:]) or valid_numbers(lows) or [float(\"nan\")])\r\n    latest_close = closes[-1]\r\n    latest_amount_ma20 = sum(valid_numbers(amounts[-20:])) / len(valid_numbers(amounts[-20:])) if valid_numbers(amounts[-20:]) else float(\"nan\")\r\n    return {\r\n        \"close\": latest_close,\r\n        \"ma20\": ma20[-1],\r\n        \"ma20_prev5\": ma20[-6] if len(ma20) >= 6 else float(\"nan\"),\r\n        \"ma50\": ma50[-1],\r\n        \"ma150\": ma150[-1],\r\n        \"ma200\": ma200[-1],\r\n        \"ma200_prev20\": ma200[-21] if len(ma200) >= 21 else float(\"nan\"),\r\n        \"rsi14\": rsi14[-1],\r\n        \"vol_ma20\": vol_ma20[-1],\r\n        \"amount_ma20\": latest_amount_ma20,\r\n        \"high52\": high52,\r\n        \"low52\": low52,\r\n        \"high20\": max(valid_numbers(highs[-20:]) or [float(\"nan\")]),\r\n        \"low10\": min(valid_numbers(lows[-10:]) or [float(\"nan\")]),\r\n        \"low20\": min(valid_numbers(lows[-20:]) or [float(\"nan\")]),\r\n        \"distance_to_52w_high\": (high52 - latest_close) / high52 if high52 and not math.isnan(high52) else float(\"nan\"),\r\n        \"distance_from_52w_low\": (latest_close - low52) / low52 if low52 and not math.isnan(low52) else float(\"nan\"),\r\n        \"latest_amount\": amounts[-1] if amounts else float(\"nan\"),\r\n        \"rows\": rows,\r\n    }\r\n\r\n\r\ndef trend_template_flags(metrics: dict[str, Any]) -> dict[str, bool]:\r\n    return {\r\n        \"close_gt_ma50\": bool(metrics[\"close\"] > metrics[\"ma50\"]) if not math.isnan(metrics[\"ma50\"]) else False,\r\n        \"close_gt_ma150\": bool(metrics[\"close\"] > metrics[\"ma150\"]) if not math.isnan(metrics[\"ma150\"]) else False,\r\n        \"close_gt_ma200\": bool(metrics[\"close\"] > metrics[\"ma200\"]) if not math.isnan(metrics[\"ma200\"]) else False,\r\n        \"ma50_gt_ma150\": bool(metrics[\"ma50\"] > metrics[\"ma150\"]) if not math.isnan(metrics[\"ma50\"]) and not math.isnan(metrics[\"ma150\"]) else False,\r\n        \"ma150_gt_ma200\": bool(metrics[\"ma150\"] > metrics[\"ma200\"]) if not math.isnan(metrics[\"ma150\"]) and not math.isnan(metrics[\"ma200\"]) else False,\r\n        \"ma200_slope_20d_gt_zero\": bool(metrics[\"ma200\"] - metrics[\"ma200_prev20\"] > 0) if not math.isnan(metrics[\"ma200\"]) and not math.isnan(metrics[\"ma200_prev20\"]) else False,\r\n        \"distance_to_52w_high_lte_25pct\": bool(metrics[\"distance_to_52w_high\"] <= 0.25) if not math.isnan(metrics[\"distance_to_52w_high\"]) else False,\r\n        \"distance_from_52w_low_gte_30pct\": bool(metrics[\"distance_from_52w_low\"] >= 0.30) if not math.isnan(metrics[\"distance_from_52w_low\"]) else False,\r\n    }\r\n\r\n\r\ndef trend_template_pass(flags: dict[str, bool]) -> tuple[bool, int]:\r\n    required_keys = (\r\n        \"close_gt_ma50\",\r\n        \"close_gt_ma150\",\r\n        \"close_gt_ma200\",\r\n        \"ma50_gt_ma150\",\r\n        \"ma150_gt_ma200\",\r\n    )\r\n    if not all(flags.get(key, False) for key in required_keys):\r\n        return False, sum(1 for value in flags.values() if value)\r\n    passed_count = sum(1 for value in flags.values() if value)\r\n    return passed_count >= 7, passed_count\r\n\r\n\r\ndef segment_amplitude(rows: list[dict[str, Any]]) -> float:\r\n    highs = valid_numbers([float(item.get(\"high\") or float(\"nan\")) for item in rows])\r\n    lows = valid_numbers([float(item.get(\"low\") or float(\"nan\")) for item in rows])\r\n    closes = valid_numbers([float(item.get(\"close\") or float(\"nan\")) for item in rows])\r\n    if not highs or not lows or not closes:\r\n        return float(\"nan\")\r\n    return (max(highs) - min(lows)) / closes[-1]\r\n\r\n\r\ndef segment_avg_volume(rows: list[dict[str, Any]]) -> float:\r\n    volumes = valid_numbers([float(item.get(\"vol\") or float(\"nan\")) for item in rows])\r\n    return sum(volumes) / len(volumes) if volumes else float(\"nan\")\r\n\r\n\r\ndef classify_vcp(metrics: dict[str, Any]) -> dict[str, Any]:\r\n    rows = safe_list(metrics.get(\"rows\"))\r\n    if len(rows) < 45:\r\n        return {\"classification\": \"fail_vcp\", \"score\": 0, \"note\": \"insufficient_history\"}\r\n    contraction40 = rows[-45:-5]\r\n    blocks40 = [contraction40[index : index + 10] for index in range(0, 40, 10)]\r\n    amp = [segment_amplitude(block) for block in blocks40]\r\n    avg_vol_block4 = segment_avg_volume(blocks40[-1])\r\n    avg_vol_prior20 = segment_avg_volume(contraction40[-20:])\r\n    recent5 = rows[-5:]\r\n    prior20_high = max(valid_numbers([float(item.get(\"high\") or float(\"nan\")) for item in contraction40[-20:]]) or [float(\"nan\")])\r\n    breakout = any(\r\n        float(item.get(\"close\") or 0.0) >= prior20_high * 0.995\r\n        and float(item.get(\"vol\") or 0.0) >= float(metrics.get(\"vol_ma20\") or 0.0) * 1.5\r\n        for item in recent5\r\n    ) if not math.isnan(prior20_high) and not math.isnan(float(metrics.get(\"vol_ma20\") or float(\"nan\"))) else False\r\n    strict_pass = (\r\n        not any(math.isnan(value) for value in amp[1:])\r\n        and amp[3] < amp[2] < amp[1]\r\n        and amp[3] <= 0.08\r\n        and (amp[3] / amp[1] <= 0.70 if amp[1] else False)\r\n        and not math.isnan(avg_vol_block4)\r\n        and not math.isnan(avg_vol_prior20)\r\n        and avg_vol_block4 <= avg_vol_prior20 * 0.75\r\n        and breakout\r\n    )\r\n    if strict_pass:\r\n        return {\"classification\": \"strict_vcp\", \"score\": 10, \"note\": f\"strict ({amp[3]:.3f})\"}\r\n    recent30 = rows[-30:]\r\n    blocks30 = [recent30[index : index + 10] for index in range(0, 30, 10)]\r\n    amp30 = [segment_amplitude(block) for block in blocks30]\r\n    recent5_avg_vol = segment_avg_volume(rows[-5:])\r\n    near_pass = (\r\n        not any(math.isnan(value) for value in amp30)\r\n        and amp30[2] < amp30[1] < amp30[0]\r\n        and amp30[2] <= 0.12\r\n        and not math.isnan(recent5_avg_vol)\r\n        and not math.isnan(avg_vol_prior20)\r\n        and recent5_avg_vol <= avg_vol_prior20 * 0.85\r\n    )\r\n    if near_pass:\r\n        return {\"classification\": \"near_vcp\", \"score\": 5, \"note\": f\"near ({amp30[2]:.3f})\"}\r\n    return {\"classification\": \"fail_vcp\", \"score\": 0, \"note\": \"no_contraction\"}\r\n\r\n\r\ndef benchmark_return(metrics: dict[str, Any], lookback_days: int) -> float:\r\n    rows = safe_list(metrics.get(\"rows\"))\r\n    if len(rows) <= lookback_days:\r\n        return float(\"nan\")\r\n    start_close = float(rows[-lookback_days - 1].get(\"close\") or float(\"nan\"))\r\n    end_close = float(rows[-1].get(\"close\") or float(\"nan\"))\r\n    if math.isnan(start_close) or start_close == 0 or math.isnan(end_close):\r\n        return float(\"nan\")\r\n    return (end_close / start_close) - 1.0\r\n\r\n\r\ndef normalize_explicit_event(event: dict[str, Any]) -> dict[str, Any]:\r\n    return {\r\n        \"title\": clean_text(event.get(\"title\")),\r\n        \"event_type\": clean_text(event.get(\"event_type\")),\r\n        \"event_date\": clean_text(event.get(\"event_date\")),\r\n        \"published_at\": clean_text(event.get(\"published_at\")),\r\n        \"source\": clean_text(event.get(\"source\")) or \"request_structured_event\",\r\n        \"structured\": True,\r\n    }\r\n\r\n\r\ndef structured_events_from_request(request: dict[str, Any], candidate: dict[str, Any]) -> list[dict[str, Any]]:\r\n    mapping = safe_dict(request.get(\"structured_events_by_ticker\"))\r\n    keys: list[str] = []\r\n    for key in (clean_text(candidate.get(\"ticker\")), clean_text(candidate.get(\"code\"))):\r\n        keys.extend(alternate_a_share_keys(key))\r\n    for key in unique_strings(keys):\r\n        events = safe_list(mapping.get(key))\r\n        if events:\r\n            return [normalize_explicit_event(item) for item in events if isinstance(item, dict)]\r\n    return []\r\n\r\n\r\ndef strip_html_tags(text: str) -> str:\r\n    cleaned = re.sub(r\"(?is)<(script|style|noscript)[^>]*>.*?</\\1>\", \" \", text)\r\n    cleaned = re.sub(r\"(?i)<br\\s*/?>\", \"\\n\", cleaned)\r\n    cleaned = re.sub(r\"(?i)</?(?:tr|table|thead|tbody|tfoot|li|ul|ol|p|div|section|article|h[1-6])[^>]*>\", \"\\n\", cleaned)\r\n    cleaned = re.sub(r\"(?i)</?(?:td|th|span|a|strong|em|b|i)[^>]*>\", \" \", cleaned)\r\n    cleaned = re.sub(r\"<[^>]+>\", \" \", cleaned)\r\n    cleaned = unescape(cleaned)\r\n    cleaned = cleaned.replace(\"\\r\", \"\\n\")\r\n    lines = [clean_text(line) for line in cleaned.split(\"\\n\")]\r\n    return \"\\n\".join(line for line in lines if line)\r\n\r\n\r\ndef classify_structured_event_type(text: str) -> str:\r\n    line = clean_text(text)\r\n    for key, keywords in STRUCTURED_EVENT_KEYWORDS.items():\r\n        if any(keyword in line for keyword in keywords):\r\n            return key\r\n    return \"\"\r\n\r\n\r\ndef classify_earnings_schedule_text(text: str) -> str:\r\n    line = clean_text(text)\r\n    if not line:\r\n        return \"\"\r\n    if (\"ж£∞еЛђеІ≠йЧЗ? in line or \"йОґоВ¶жєґ\" in line) and any(\r\n        keyword in line\r\n        for keyword in (\r\n            \"й™Юе≠ШеІ§\",\r\n            \"жґУвВђзАЫпљЖеІ§\",\r\n            \"зАЫпљЖеІ§\",\r\n            \"йНЧе©ВеЛЊйОґ?,\r\n            \"жґУоЕЯеІ§\",\r\n            \"жґУе§КоДЬйОґ?,\r\n            \"зАєж∞≠жє°йОґгГ•жЖ°\",\r\n        )\r\n    ):\r\n        return \"scheduled_earnings\"\r\n    return classify_structured_event_type(line)\r\n\r\n\r\ndef dedupe_structured_events(events: list[dict[str, Any]]) -> list[dict[str, Any]]:\r\n    deduped: list[dict[str, Any]] = []\r\n    seen: set[str] = set()\r\n    for item in events:\r\n        key = f\"{clean_text(item.get('event_type'))}|{clean_text(item.get('event_date'))}|{clean_text(item.get('title'))}\"\r\n        if key in seen:\r\n            continue\r\n        seen.add(key)\r\n        deduped.append(item)\r\n    return deduped[:20]\r\n\r\n\r\n"}}
