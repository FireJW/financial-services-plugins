{"timestamp":"2026-04-14T02:58:07.380Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_W2X5cImHcVu3nMfoZcq3zdLw","output":"Exit code: 0\nWall time: 0.5 seconds\nOutput:\n\r\n    # йИєвВђйИєвВђ Spec Change #1: Degraded Mode йИєвВђйИєвВђ\r\n\r\n    def test_degraded_mode_set_on_universe_fetch_failure(self) -> None:\r\n        \"\"\"When universe fetch fails and no seeded candidates, result should have degraded_mode=True.\"\"\"\r\n        raw_request = normalize_request({\r\n            \"analysis_date\": \"2026-04-13\",\r\n            \"target_date\": \"2026-04-14\",\r\n            \"themes\": [\"electronic_cloth\"],\r\n            \"focus_tickers\": [\"603256.SS\"],\r\n            \"runtime_warnings\": [\"universe_fetch_failed:eastmoney+tushare:WinError 10013\"],\r\n        })\r\n        # Simulate: universe_fetch_warning returns non-empty, no universe_candidates\r\n        from month_end_shortlist_runtime import universe_fetch_warning\r\n        self.assertTrue(universe_fetch_warning(raw_request))\r\n        self.assertFalse(bool(raw_request.get(\"universe_candidates\")))\r\n\r\n        # Build a minimal result dict to test the degraded mode logic\r\n        has_universe_fetch_failure = bool(universe_fetch_warning(raw_request))\r\n        has_seeded_universe = bool(raw_request.get(\"universe_candidates\"))\r\n        if has_universe_fetch_failure and not has_seeded_universe:\r\n            degraded_mode = True\r\n            result_scope = \"focus_tickers_only\"\r\n        else:\r\n            degraded_mode = False\r\n            result_scope = \"full_universe\"\r\n        self.assertTrue(degraded_mode)\r\n        self.assertEqual(result_scope, \"focus_tickers_only\")\r\n\r\n    # йИєвВђйИєвВђ Spec Change #2: Enriched Path йИєвВђйИєвВђ\r\n\r\n    def test_enriched_path_skips_live_fetch(self) -> None:\r\n        \"\"\"When universe_candidates is provided, live fetch should not be attempted.\"\"\"\r\n        raw_request = normalize_request({\r\n            \"analysis_date\": \"2026-04-13\",\r\n            \"target_date\": \"2026-04-14\",\r\n            \"themes\": [\"electronic_cloth\"],\r\n            \"universe_candidates\": [\r\n                {\"ticker\": \"603256.SS\", \"code\": \"603256\", \"name\": \"зАєењУжЛ∞зїЙжИЮе¶І\", \"price\": 30.0},\r\n            ],\r\n            \"history_by_ticker\": {\r\n                \"603256.SS\": [{\"trade_date\": \"2026-04-10\", \"open\": 28, \"high\": 30, \"low\": 27, \"close\": 29, \"volume\": 1e6, \"amount\": 3e7, \"pct_chg\": 3.5}],\r\n            },\r\n        })\r\n        # Verify the enriched path is used: universe_candidates is non-empty\r\n        self.assertTrue(bool(raw_request.get(\"universe_candidates\")))\r\n        # Verify history_from_request returns data for the seeded ticker\r\n        from month_end_shortlist_runtime import history_from_request\r\n        result = history_from_request(raw_request, {\"ticker\": \"603256.SS\", \"code\": \"603256\"})\r\n        self.assertIsNotNone(result)\r\n        self.assertGreater(len(result), 0)\r\n\r\n    # йИєвВђйИєвВђ Spec Change #4: Leg Mapping йИєвВђйИєвВђ\r\n\r\n    def test_leg_mapping_from_top_picks(self) -> None:\r\n        \"\"\"Leg mapping should be computed from top picks.\"\"\"\r\n        top_picks = [\r\n            {\"ticker\": \"600176.SS\", \"name\": \"жґУоЕЮжµЧеЃЄгДІзЕґ\", \"score\": 79.4},\r\n            {\"ticker\": \"603256.SS\", \"name\": \"зАєењУжЛ∞зїЙжИЮе¶І\", \"score\": 69.8},\r\n        ]\r\n        from month_end_shortlist_runtime import clean_text\r\n        leg_mapping = {\r\n            \"primary_leg\": clean_text(top_picks[0].get(\"name\")) if len(top_picks) >= 1 else None,\r\n            \"confirm_leg\": clean_text(top_picks[1].get(\"name\")) if len(top_picks) >= 2 else None,\r\n            \"hedge_leg\": None,\r\n            \"mapping_basis\": \"shortlist_score_rank\",\r\n            \"as_of\": \"2026-04-13\",\r\n        }\r\n        self.assertEqual(leg_mapping[\"primary_leg\"], \"жґУоЕЮжµЧеЃЄгДІзЕґ\")\r\n        self.assertEqual(leg_mapping[\"confirm_leg\"], \"зАєењУжЛ∞зїЙжИЮе¶І\")\r\n        self.assertIsNone(leg_mapping[\"hedge_leg\"])\r\n        self.assertEqual(leg_mapping[\"mapping_basis\"], \"shortlist_score_rank\")\r\n\r\n    # йИєвВђйИєвВђ Spec Change #3: Freshness Guard йИєвВђйИєвВђ\r\n\r\n    def test_freshness_guard_rejects_stale(self) -> None:\r\n        \"\"\"Trade card should include price_as_of field.\"\"\"\r\n        candidate = {\r\n            \"ticker\": \"603256.SS\",\r\n            \"code\": \"603256\",\r\n            \"name\": \"зАєењУжЛ∞зїЙжИЮе¶І\",\r\n            \"board\": \"main_board\",\r\n            \"metrics\": {\"close\": 30.0, \"ma20\": 29.0, \"ma50\": 28.0, \"trade_date\": \"2026-04-13\"},\r\n        }\r\n        profile = FILTER_PROFILES[\"month_end_generic\"]\r\n        card = trade_card(candidate, profile)\r\n        self.assertIn(\"price_as_of\", card)\r\n        self.assertEqual(card[\"price_as_of\"], \"2026-04-13\")\r\n\r\n    # йИєвВђйИєвВђ Spec Change #1: Failure Categories йИєвВђйИєвВђ\r\n"}}
