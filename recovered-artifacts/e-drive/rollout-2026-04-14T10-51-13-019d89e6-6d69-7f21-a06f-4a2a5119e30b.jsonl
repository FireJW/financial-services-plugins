{"timestamp":"2026-04-14T02:55:31.127Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_ZfzwuHwJno9Y1qXtRQq7uDgz","output":"Exit code: 0\nWall time: 0.4 seconds\nOutput:\n/**\r\n * Daily Trade Plan Validation йИ•?CLI Entrypoint\r\n *\r\n * Usage:\r\n *   node scripts/legendary-investor-daily-validation.mjs \\\r\n *     --mode intraday|postclose \\\r\n *     [--run-json-file <path>]   # defaults to handoff/legendary-investor-last-run.json\r\n *     [--facts-file <path>]      # JSON file with intraday or postclose facts\r\n *     [--fact key=value]          # inline fact overrides\r\n *     [--x-signals-file <path>]  # optional X supplementation signals JSON\r\n *     [--write-json]             # persist validation record\r\n *     [--output-json-file <path>] # custom output path\r\n *     [--json]                   # output JSON to stdout\r\n *     [--dry-run]                # show what would happen without running\r\n *\r\n * The loop:\r\n *   plan (last-run.json) + intraday facts -> intraday validation (partial/too_early)\r\n *   plan (last-run.json) + postclose facts -> full validation (success/partial/fail/too_early)\r\n */\r\n\r\nimport fs from \"node:fs\";\r\nimport path from \"node:path\";\r\nimport { pathToFileURL } from \"node:url\";\r\nimport { loadConfig } from \"../src/config.mjs\";\r\nimport {\r\n  runDailyValidation,\r\n  renderValidationRecord,\r\n  buildIntradayFacts,\r\n  buildPostcloseFacts\r\n} from \"../src/legendary-investor-daily-validation.mjs\";\r\nimport {\r\n  loadValidationRecords,\r\n  aggregateValidationRecords,\r\n  renderValidationLedger\r\n} from \"../src/legendary-investor-validation-ledger.mjs\";\r\n\r\nexport function parseDailyValidationArgs(args = []) {\r\n  const list = Array.isArray(args) ? args : [];\r\n  const mode = String(getArg(list, \"mode\") || \"postclose\").trim().toLowerCase();\r\n  return {\r\n    mode,\r\n    runJsonFile: String(getArg(list, \"run-json-file\") || \"\").trim(),\r\n    factsFile: String(getArg(list, \"facts-file\") || \"\").trim(),\r\n    xSignalsFile: String(getArg(list, \"x-signals-file\") || \"\").trim(),\r\n    facts: collectFactArgs(list),\r\n    writeJson: list.includes(\"--write-json\"),\r\n    outputJsonFile: String(getArg(list, \"output-json-file\") || \"\").trim(),\r\n    json: list.includes(\"--json\"),\r\n    dryRun: list.includes(\"--dry-run\"),\r\n    ledger: list.includes(\"--ledger\"),\r\n    ledgerDir: String(getArg(list, \"ledger-dir\") || \"\").trim()\r\n  };\r\n}\r\n\r\nexport function runDailyValidationCli(args = process.argv.slice(2), runtime = {}) {\r\n  const command = parseDailyValidationArgs(args);\r\n\r\n  const config = runtime.config || loadConfig();\r\n  const writer = runtime.writer || console;\r\n\r\n  // Ledger mode: aggregate past validation records\r\n  if (command.ledger) {\r\n    const ledgerDir = command.ledgerDir\r\n      ? path.resolve(config.projectRoot, command.ledgerDir)\r\n      : path.join(config.projectRoot, \"handoff\");\r\n    const records = loadValidationRecords(ledgerDir);\r\n    const aggregation = aggregateValidationRecords(records);\r\n\r\n    if (command.json) {\r\n      writer.log(JSON.stringify(aggregation, null, 2));\r\n    } else {\r\n      writer.log(renderValidationLedger(aggregation));\r\n    }\r\n    return { ledger: true, aggregation };\r\n  }\r\n\r\n  if (![\"intraday\", \"postclose\"].includes(command.mode)) {\r\n    throw new Error(`Unsupported --mode: ${command.mode}. Use \"intraday\" or \"postclose\".`);\r\n  }\r\n\r\n"}}
