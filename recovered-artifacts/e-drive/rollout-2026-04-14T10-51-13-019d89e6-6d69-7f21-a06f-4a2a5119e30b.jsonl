ss\" if profile.trend_policy == \"repair_rebound\" and safe_dict(candidate.get(\"repair_rebound\")).get(\"pass\") else \"\",\r\n                \"rs_above_threshold\" if float(candidate.get(\"rs90\") or 0.0) >= float(request.get(\"rs_threshold\") or 0.0) else \"\",\r\n                \"structured_catalyst_within_window\" if catalyst_policy_pass(candidate, profile) else \"\",\r\n                \"risk_reward_pass\" if safe_dict(candidate.get(\"risk_reward\")).get(\"pass\") else \"\",\r\n                \"fundamental_acceleration_pass\" if safe_dict(candidate.get(\"acceleration\")).get(\"fundamental_acceleration_pass\") else \"\",\r\n            )\r\n            if reason\r\n        ],\r\n        \"why_not_ranked_higher\": gaps,\r\n    }\r\n\r\n\r\ndef focus_diagnostic_record(candidate: dict[str, Any], request: dict[str, Any], profile: FilterProfile) -> dict[str, Any]:\r\n    if clean_text(candidate.get(\"drop_reason\")):\r\n        base = deepcopy(candidate)\r\n        base[\"focus_requested\"] = True\r\n        catalyst = safe_dict(base.get(\"structured_catalyst\"))\r\n        return {\r\n            **shortlist_record(base),\r\n            \"status\": \"dropped\",\r\n            \"drop_reason\": clean_text(base.get(\"drop_reason\")),\r\n            \"why_kept\": [],\r\n            \"why_not_ranked_higher\": top_pick_gaps(base, profile, request) if \"score_components\" in base else [],\r\n            \"catalyst_summary\": deepcopy(catalyst),\r\n            \"price_paths\": deepcopy(safe_dict(base.get(\"price_paths\"))) or (price_paths(base, request, profile) if safe_dict(base.get(\"metrics\")) else {}),\r\n            \"trade_card\": deepcopy(safe_dict(base.get(\"trade_card\"))) or (trade_card(base, profile) if safe_dict(base.get(\"metrics\")) else {}),\r\n            \"backtest_summary\": deepcopy(safe_dict(base.get(\"backtest_summary\"))) if safe_dict(base.get(\"metrics\")) and request.get(\"backtest_mode\") == \"recent_shortlist_validation\" else {},\r\n            \"risk_reward\": deepcopy(safe_dict(base.get(\"risk_reward\"))),\r\n        }\r\n    selection_mode = \"strict\" if not top_pick_gaps(candidate, profile, request) else top_pick_selection_bucket(candidate, profile, request)\r\n    record = top_pick_record(candidate, request, profile, selection_mode=selection_mode)\r\n    record[\"status\"] = \"kept\"\r\n    record[\"drop_reason\"] = \"\"\r\n    return record\r\n\r\n\r\ndef build_focus_diagnostics(kept: list[dict[str, Any]], dropped: list[dict[str, Any]], request: dict[str, Any], profile: FilterProfile) -> list[dict[str, Any]]:\r\n    focus_tickers = [clean_text(item) for item in safe_list(request.get(\"focus_tickers\")) if clean_text(item)]\r\n    if not focus_tickers:\r\n        return []\r\n    focus_lookup = {ticker: True for ticker in focus_tickers}\r\n    candidate_index = {\r\n        clean_text(item.get(\"ticker\")): item\r\n        for item in [*kept, *dropped]\r\n        if clean_text(item.get(\"ticker\"))\r\n    }\r\n"}}
