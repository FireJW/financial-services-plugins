{"timestamp":"2026-04-14T02:59:29.456Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_oxRhFEvrx666sUxJNkufybdc","output":"Exit code: 0\nWall time: 1.3 seconds\nOutput:\ndef candidate_has_core_x_style_support(candidate: dict[str, Any]) -> bool:\r\n    reasons = [\r\n        clean_text(value)\r\n        for value in safe_list(safe_dict(candidate.get(\"score_components\")).get(\"x_style_overlay_adjustment_reasons\"))\r\n        if clean_text(value)\r\n    ]\r\n    return any(reason.startswith(\"x_style_named_pick:\") or reason.startswith(\"x_style_basket_core:\") for reason in reasons)\r\n\r\n\r\ndef top_pick_gaps(candidate: dict[str, Any], profile: FilterProfile, request: dict[str, Any] | None = None) -> list[str]:\r\n    request = request or {}\r\n    acceleration = safe_dict(candidate.get(\"acceleration\"))\r\n    risk_reward = safe_dict(candidate.get(\"risk_reward\"))\r\n    score = float(candidate.get(\"score\") or 0.0)\r\n    gaps: list[str] = []\r\n    if profile.require_fundamental_acceleration_for_top_picks and not acceleration.get(\"fundamental_acceleration_pass\"):\r\n        gaps.append(\"fundamental_acceleration_missing\")\r\n    if not catalyst_policy_pass(candidate, profile):\r\n        gaps.append(catalyst_failure_reason(profile))\r\n    if risk_reward.get(\"pass\") is False:\r\n        gaps.append(\"risk_reward_below_min\")\r\n    if score < profile.top_pick_keep_line:\r\n        gaps.append(\"score_below_top_pick_keep_line\")\r\n    if request_requires_core_x_style_match_for_top_picks(request) and not candidate_has_core_x_style_support(candidate):\r\n        gaps.append(\"x_style_core_match_required\")\r\n    return gaps\r\n\r\n\r\ndef top_pick_selection_bucket(candidate: dict[str, Any], profile: FilterProfile, request: dict[str, Any] | None = None) -> str:\r\n    gaps = top_pick_gaps(candidate, profile, request)\r\n    if not gaps:\r\n        return \"strict\"\r\n    allowed_near_strict_gaps = {\"fundamental_acceleration_missing\", \"score_below_top_pick_keep_line\"}\r\n    score = float(candidate.get(\"score\") or 0.0)\r\n    score_shortfall = max(profile.top_pick_keep_line - score, 0.0)\r\n    if set(gaps).issubset(allowed_near_strict_gaps) and score_shortfall <= 5.0:\r\n        return \"near_strict\"\r\n    return \"weak_fallback\"\r\n\r\n\r\nOVERLAY_SECTOR_ADJUSTMENT_CAP = 2.5\r\nOVERLAY_TOTAL_ADJUSTMENT_CAP = 3.0\r\nX_STYLE_OVERLAY_ADJUSTMENT_CAP = 5.0\r\nMACRO_HEALTH_OVERLAY_ADJUSTMENT_CAP = 1.0\r\n\r\nX_STYLE_THEME_KEYWORDS = {\r\n    \"electronic_cloth\": (\"йРҐйЭЫзУЩзФѓ?, \"йРҐйЭЫзУЩзїЊ?, \"зСХеЧЫжСРйПЙ?, \"CCL\", \"йРЬиН§ж∞¶\", \"йПЙжД≠жЮ°\"),\r\n    \"optical_interconnect\": (\"йНПе§ЛƒБйНІ?, \"йНПе§Йз∞∞йС±?, \"йНПе§РвВђж∞ЂдњК\", \"йНПе§ОеІ±йРЧ?, \"CPO\", \"OCS\", \"EML\", \"DFB\", \"зЇ≠еС≠еОЬ\"),\r\n    \"advanced_pcb_flexible\": (\"FOLP\", \"FCCL\", \"PI\", \"йПМжЧАвВђоЬЦCB\", \"йРҐдљГзЯЊйПЙ?),\r\n    \"satellite_chain\": (\"йНЧоВ£жІ¶\", \"йСЄоБДгБЙ\"),\r\n    \"cleanroom\": (\"е®≤дљЄеЩ£зАє?, \"е®≤дљЄеЩ£\"),\r\n    \"fiber_cable\": (\"йНПе§Мж∞¶\", \"йНПе§МзіЧ\", \"е®ій£ОзіЧ\"),\r\n    \"pcb_equipment\": (\"PCB\", \"зТБжГІоШђ\", \"йЦљиѓ≤зУЯ\", \"LDI\"),\r\n    \"oil_shipping\": (\"е®Мз°ЕзєН\", \"йСЄоБЗзєН\"),\r\n}\r\n\r\nX_STYLE_GENERIC_NAME_KEYWORDS = {\"йПЙжД≠жЮ°\", \"зТБжГІоШђ\"}\r\n\r\nDEFENSIVE_STYLE_TOKENS = (\r\n    \"defensive\",\r\n    \"grid\",\r\n    \"utility\",\r\n    \"gold\",\r\n    \"precious\",\r\n    \"energy\",\r\n    \"telecom\",\r\n    \"bank\",\r\n    \"insurance\",\r\n    \"dividend\",\r\n    \"power_grid_equipment\",\r\n    \"gold_and_precious_metals\",\r\n)\r\n\r\nGROWTH_BETA_STYLE_TOKENS = (\r\n    \"growth\",\r\n    \"beta\",\r\n    \"ai\",\r\n    \"cpo\",\r\n    \"optical\",\r\n    \"semiconductor\",\r\n    \"chip\",\r\n    \"software\",\r\n    \"internet\",\r\n    \"new_energy\",\r\n    \"consumer_discretionary\",\r\n    \"cpo_and_optical_interconnect\",\r\n)\r\n\r\n\r\ndef classify_sector_bias(text: str) -> str:\r\n    normalized = normalized_match_text(text)\r\n    overweight_tokens = (\"overweight\", \"favored\", \"prefer\", \"long\", \"bullish\")\r\n    underweight_tokens = (\"underweight\", \"avoid\", \"reduce\", \"selective\", \"cautious\", \"defensiveonly\")\r\n    if any(token in normalized for token in overweight_tokens):\r\n        return \"overweight\"\r\n    if any(token in normalized for token in underweight_tokens):\r\n        return \"underweight\"\r\n    return \"neutral\"\r\n\r\n\r\ndef candidate_matches_sector_view(candidate: dict[str, Any], sector_view: dict[str, Any]) -> tuple[bool, bool, bool]:\r\n    ticker = clean_text(candidate.get(\"ticker\"))\r\n    leader = clean_text(sector_view.get(\"leader_ticker\"))\r\n    core_tickers = {clean_text(value) for value in safe_list(sector_view.get(\"core_tickers\")) if clean_text(value)}\r\n    candidate_sector = normalized_match_text(candidate.get(\"sector\"))\r\n    sector_hints = [\r\n        normalized_match_text(value)\r\n        for value in [sector_view.get(\"sector\"), *safe_list(sector_view.get(\"sector_aliases\"))]\r\n        if clean_text(value)\r\n    ]\r\n    core_match = ticker in core_tickers\r\n    leader_match = bool(leader) and ticker == leader\r\n    sector_match = any(bool(hint) and bool(candidate_sector) and hint in candidate_sector for hint in sector_hints)\r\n    return sector_match or core_match or leader_match, core_match, leader_match\r\n\r\n\r\ndef candidate_style_profile(candidate: dict[str, Any]) -> str:\r\n    bucket = \" \".join(\r\n        [\r\n            clean_text(candidate.get(\"sector\")),\r\n            clean_text(candidate.get(\"name\")),\r\n            clean_text(safe_dict(candidate.get(\"theme_alignment\")).get(\"matched_theme_labels\")),\r\n        ]\r\n    ).lower()\r\n    if any(token in bucket for token in DEFENSIVE_STYLE_TOKENS):\r\n"}}
