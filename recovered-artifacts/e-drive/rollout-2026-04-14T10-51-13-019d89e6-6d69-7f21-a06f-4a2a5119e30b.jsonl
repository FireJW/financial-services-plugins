{"timestamp":"2026-04-14T03:28:51.467Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_kPFqsUEKHhHBfv7jTGXJNvgP","output":"Exit code: 0\nWall time: 0.6 seconds\nOutput:\n    if board == \"chinext\":\r\n        if code in request[\"chinext_whitelist\"]:\r\n            return True, \"\"\r\n        return False, \"chinext_not_whitelisted\"\r\n    if board != \"main_board\":\r\n        return False, \"not_in_allowed_board_scope\"\r\n    return True, \"\"\r\n\r\n\r\ndef history_lookup_key(candidate: dict[str, Any]) -> str:\r\n    return clean_text(candidate.get(\"ticker\") or candidate.get(\"code\"))\r\n\r\n\r\ndef alternate_a_share_keys(value: str) -> list[str]:\r\n    text = clean_text(value).upper()\r\n    if text.endswith(\".SS\"):\r\n        return [text, text[:-3] + \".SH\", text[:-3]]\r\n    if text.endswith(\".SH\"):\r\n        return [text, text[:-3] + \".SS\", text[:-3]]\r\n    if text.endswith(\".SZ\"):\r\n        return [text, text[:-3]]\r\n    if re.fullmatch(r\"\\d{6}\", text):\r\n        try:\r\n            normalized = normalized_a_share_ticker(text)\r\n        except ValueError:\r\n            return [text]\r\n        return alternate_a_share_keys(normalized)\r\n    return [text]\r\n\r\n\r\ndef normalize_history_row(row: dict[str, Any]) -> dict[str, Any]:\r\n    return {\r\n        \"trade_date\": clean_text(row.get(\"trade_date\") or row.get(\"date\")),\r\n        \"open\": float(row.get(\"open\") or 0.0),\r\n        \"high\": float(row.get(\"high\") or 0.0),\r\n        \"low\": float(row.get(\"low\") or 0.0),\r\n        \"close\": float(row.get(\"close\") or 0.0),\r\n        \"vol\": float(row.get(\"vol\") or row.get(\"volume\") or 0.0),\r\n        \"amount\": float(row.get(\"amount\") or row.get(\"amt\") or 0.0),\r\n        \"pct_chg\": float(row.get(\"pct_chg\") or row.get(\"pct\") or 0.0),\r\n    }\r\n\r\n\r\ndef throttle_eastmoney_history_requests() -> None:\r\n    global _LAST_EASTMONEY_HISTORY_REQUEST_AT\r\n    now = time.monotonic()\r\n    wait_seconds = EASTMONEY_HISTORY_THROTTLE_SECONDS - (now - _LAST_EASTMONEY_HISTORY_REQUEST_AT)\r\n    if wait_seconds > 0:\r\n        time.sleep(wait_seconds)\r\n    _LAST_EASTMONEY_HISTORY_REQUEST_AT = time.monotonic()\r\n\r\n\r\ndef format_date_yyyymmdd(value: str) -> str:\r\n    parsed = datetime.strptime(clean_text(value), \"%Y-%m-%d\")\r\n    return parsed.strftime(\"%Y%m%d\")\r\n\r\n\r\ndef tencent_symbol(ticker: str) -> str:\r\n    normalized = normalized_a_share_ticker(ticker)\r\n    digits = normalized[:-3]\r\n    suffix = normalized[-2:]\r\n    return (\"sh\" if suffix in {\"SS\", \"SH\"} else \"sz\") + digits\r\n\r\n\r\ndef fetch_tencent_qfq_history_rows(candidate: dict[str, Any], start_date: str, end_date: str) -> list[dict[str, Any]]:\r\n    ticker = clean_text(candidate.get(\"ticker\"))\r\n    if not ticker:\r\n        return []\r\n    symbol = tencent_symbol(ticker)\r\n    query = {\r\n        \"param\": f\"{symbol},day,{start_date},{end_date},400,qfq\",\r\n    }\r\n    request = Request(\r\n        f\"{TENCENT_KLINE_URL}?{urlencode(query)}\",\r\n        headers={\r\n            \"User-Agent\": \"Mozilla/5.0\",\r\n            \"Referer\": \"https://gu.qq.com/\",\r\n            \"Accept\": \"application/json,text/plain,*/*\",\r\n        },\r\n        method=\"GET\",\r\n    )\r\n    with urlopen(request, timeout=20) as response:\r\n        payload = json.loads(response.read().decode(\"utf-8\"))\r\n    data = safe_dict(safe_dict(payload.get(\"data\")).get(symbol))\r\n    raw_rows = safe_list(data.get(\"qfqday\")) or safe_list(data.get(\"day\"))\r\n    rows: list[dict[str, Any]] = []\r\n    previous_close = float(\"nan\")\r\n    for item in raw_rows:\r\n        if not isinstance(item, list) or len(item) < 6:\r\n            continue\r\n        trade_date = clean_text(item[0])\r\n        open_price = float(item[1])\r\n        close_price = float(item[2])\r\n        high_price = float(item[3])\r\n        low_price = float(item[4])\r\n        volume = float(item[5])\r\n        change = close_price - previous_close if not math.isnan(previous_close) else 0.0\r\n        pct_chg = (change / previous_close * 100.0) if not math.isnan(previous_close) and previous_close != 0 else 0.0\r\n        rows.append(\r\n            {\r\n                \"trade_date\": trade_date,\r\n                \"open\": open_price,\r\n                \"high\": high_price,\r\n                \"low\": low_price,\r\n                \"close\": close_price,\r\n                \"vol\": volume,\r\n                \"amount\": 0.0,\r\n                \"pct_chg\": pct_chg,\r\n            }\r\n        )\r\n        previous_close = close_price\r\n    if not rows:\r\n        return []\r\n    return rows\r\n\r\n\r\ndef load_eastmoney_cached_history_rows(candidate: dict[str, Any], start_date: str, end_date: str) -> list[dict[str, Any]]:\r\n    ticker = clean_text(candidate.get(\"ticker\"))\r\n    if not ticker:\r\n        return []\r\n    query = {\r\n        \"fields1\": \"f1,f2,f3,f4,f5,f6\",\r\n        \"fields2\": \"f51,f52,f53,f54,f55,f56,f57,f58,f59,f60,f61\",\r\n        \"klt\": \"101\",\r\n        \"fqt\": \"0\",\r\n        \"lmt\": \"10000\",\r\n        \"ut\": clean_text(os.environ.get(\"EASTMONEY_UT\")) or EASTMONEY_DEFAULT_UT,\r\n        \"secid\": eastmoney_secid(ticker),\r\n        \"beg\": format_date_yyyymmdd(start_date),\r\n        \"end\": format_date_yyyymmdd(end_date),\r\n    }\r\n    cache_name = f\"kline-{json.dumps(query, ensure_ascii=True, sort_keys=True)}.json\"\r\n    path = eastmoney_cache_path(cache_name)\r\n    payload = read_eastmoney_cached_json(path, max_age_seconds=EASTMONEY_STALE_CACHE_MAX_AGE_SECONDS)\r\n    if payload is None:\r\n        return []\r\n    return [normalize_history_row(item) for item in parse_eastmoney_daily_items(payload)]\r\n\r\n\r\ndef filter_history_rows_by_window(rows: list[dict[str, Any]], start_date: str, end_date: str) -> list[dict[str, Any]]:\r\n    start_bound = parse_iso_date(start_date)\r\n    end_bound = parse_iso_date(end_date)\r\n    return [\r\n        row\r\n        for row in rows\r\n        if (parse_iso_date(row.get(\"trade_date\")) or date.min) >= (start_bound or date.min)\r\n        and (parse_iso_date(row.get(\"trade_date\")) or date.max) <= (end_bound or date.max)\r\n    ]\r\n\r\n\r\ndef load_any_eastmoney_cached_history_rows(candidate: dict[str, Any], start_date: str, end_date: str) -> list[dict[str, Any]]:\r\n    ticker = clean_text(candidate.get(\"ticker\"))\r\n    code = clean_text(candidate.get(\"code\")) or (ticker[:-3] if ticker.endswith((\".SS\", \".SZ\", \".SH\")) else \"\")\r\n    if not code:\r\n        return []\r\n    cache_root = eastmoney_cache_root()\r\n    if not cache_root.exists():\r\n        return []\r\n    best_rows: list[dict[str, Any]] = []\r\n    best_score = (-1, -1.0)\r\n    for path in cache_root.glob(\"kline-*.json\"):\r\n        payload = read_eastmoney_cached_json(path, max_age_seconds=EASTMONEY_STALE_CACHE_MAX_AGE_SECONDS)\r\n        if not isinstance(payload, dict):\r\n            continue\r\n        if clean_text(safe_dict(payload.get(\"data\")).get(\"code\")) != code:\r\n            continue\r\n        filtered_rows = filter_history_rows_by_window(\r\n            [normalize_history_row(item) for item in parse_eastmoney_daily_items(payload)],\r\n            start_date,\r\n            end_date,\r\n        )\r\n        if len(filtered_rows) < 221:\r\n            continue\r\n        try:\r\n            mtime = path.stat().st_mtime\r\n        except OSError:\r\n            mtime = 0.0\r\n        score = (len(filtered_rows), mtime)\r\n        if score > best_score:\r\n            best_rows = filtered_rows\r\n            best_score = score\r\n    return best_rows\r\n\r\n\r\ndef is_socket_access_denied_error(exc: Exception) -> bool:\r\n    message = clean_text(exc).lower()\r\n    return \"winerror 10013\" in message or \"forbidden by its access permissions\" in message\r\n\r\n\r\ndef attempt_eastmoney_shorter_windows(candidate: dict[str, Any], start_date: str, end_date: str) -> list[dict[str, Any]]:\r\n    ticker = clean_text(candidate.get(\"ticker\"))\r\n    end_bound = parse_iso_date(end_date)\r\n    start_bound = parse_iso_date(start_date)\r\n    if not ticker or end_bound is None or start_bound is None:\r\n        return []\r\n    fallback_starts: list[str] = []\r\n    for days in (330, 365):\r\n        alt_start = (end_bound - timedelta(days=days)).isoformat()\r\n        if alt_start > start_date and alt_start not in fallback_starts:\r\n            fallback_starts.append(alt_start)\r\n    for index, alt_start in enumerate(fallback_starts):\r\n        try:\r\n            if index > 0:\r\n                time.sleep(0.8 * index)\r\n            throttle_eastmoney_history_requests()\r\n            rows = fetch_eastmoney_daily_bars(ticker, alt_start, end_date)\r\n        except Exception:\r\n            continue\r\n        normalized_rows = [normalize_history_row(item) for item in rows]\r\n        if len(normalized_rows) >= 221:\r\n            return normalized_rows\r\n    return []\r\n\r\n\r\ndef history_from_request(request: dict[str, Any], candidate: dict[str, Any]) -> list[dict[str, Any]] | None:\r\n    history_by_ticker = safe_dict(request.get(\"history_by_ticker\"))\r\n    keys: list[str] = []\r\n    for key in (history_lookup_key(candidate), clean_text(candidate.get(\"code\"))):\r\n        keys.extend(alternate_a_share_keys(key))\r\n    for key in unique_strings(keys):\r\n        payload = safe_list(history_by_ticker.get(key))\r\n        if payload:\r\n            return [normalize_history_row(item) for item in payload if isinstance(item, dict)]\r\n    return None\r\n\r\n\r\ndef fetch_history_rows(request: dict[str, Any], candidate: dict[str, Any], start_date: str, end_date: str) -> list[dict[str, Any]]:\r\n    injected = history_from_request(request, candidate)\r\n    if injected is not None:\r\n        print(f\"[debug] using seeded history for {clean_text(candidate.get('ticker'))}, skipping live fetch\", file=sys.stderr)\r\n        return filter_history_rows_by_window(injected, start_date, end_date)\r\n    ticker = clean_text(candidate.get(\"ticker\"))\r\n    last_error: Exception | None = None\r\n    rows: list[dict[str, Any]] | None = None\r\n    for attempt in range(4):\r\n        try:\r\n            if request[\"data_provider\"] == \"tushare\":\r\n                rows = fetch_tushare_daily_bars(ticker, start_date, end_date)\r\n            else:\r\n                throttle_eastmoney_history_requests()\r\n                rows = fetch_eastmoney_daily_bars(ticker, start_date, end_date)\r\n            break\r\n        except Exception as exc:  # noqa: BLE001\r\n            last_error = exc\r\n            if request[\"data_provider\"] == \"eastmoney\" and is_socket_access_denied_error(exc):\r\n                break\r\n            time.sleep(1.0 * (attempt + 1))\r\n    if rows is None:\r\n        if request[\"data_provider\"] == \"eastmoney\":\r\n            rows = attempt_eastmoney_shorter_windows(candidate, start_date, end_date)\r\n            if not rows:\r\n                rows = load_eastmoney_cached_history_rows(candidate, start_date, end_date)\r\n            if not rows:\r\n                rows = load_any_eastmoney_cached_history_rows(candidate, start_date, end_date)\r\n            if not rows:\r\n                try:\r\n                    rows = fetch_tencent_qfq_history_rows(candidate, start_date, end_date)\r\n                except Exception:\r\n                    rows = []\r\n            if not rows:\r\n"}}
