#!/bin/sh

HOOK_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$HOOK_DIR/check_staged_artifacts.ps1"
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$HOOK_DIR/check_staged_artifacts.ps1"
fi

echo "pre-commit guard: PowerShell is required to validate the staged files."
exit 1
